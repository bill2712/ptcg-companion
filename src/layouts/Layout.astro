---
import '../styles/global.css';
import { langs, t } from '../locales/translations';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  lang?: string;
}

const { 
  title = "PTCG Companion - Live Match Assistant", 
  description = "The ultimate esports-grade Pokémon TCG damage counter and match assistant. Track VSTAR, special conditions, and damage with zero layout shift.", 
  keywords = "ptcg damage counter app, pokemon tcg match assistant, pokemon card battle calculator, vstar power tracker, tcg battle calculator", 
  lang = "en" 
} = Astro.props;

// Construct Canonical URL mathematically cleanly
const siteUrl = "https://ptcg-companion.pages.dev";
const canonicalPath = lang === 'en' ? '/' : `/${lang}/`;
const canonicalURL = new URL(canonicalPath, siteUrl).href.replace(/(?<!:)\/\/+/g, '/');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    
    <link rel="canonical" href={canonicalURL} />
    
    {/* Surgical Hreflang Architecture */}
    {langs.map(l => {
      const lPath = l === 'en' ? '/' : `/${l}/`;
      const lUrl = new URL(lPath, siteUrl).href.replace(/(?<!:)\/\/+/g, '/');
      return <link rel="alternate" hreflang={l} href={lUrl} />
    })}
    <link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl).href.replace(/(?<!:)\/\/+/g, '/')} />

    {/* Open Graph / Social Preview Graph Overhaul */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <!-- Google Consent Management Platform (CMP) Banner Block -->
    <script async src="https://fundingchoicesmessages.google.com/i/pub-0000000000000000/messages.js" data-ncp="true"></script>

    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9R61GZ220P"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9R61GZ220P');

      // Nuke legacy Coffee Timer Service Workers
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then(function(registrations) {
          for(let registration of registrations) {
            registration.unregister();
            console.log('Legacy ServiceWorker unregistered.');
          }
        });
      }
    </script>
  </head>
  <body class="h-screen w-full flex flex-col justify-between bg-black text-white overflow-hidden selection:bg-gray-800">
    <div class="flex-1 w-full flex flex-col min-h-0 overflow-hidden relative">
      <slot />
    </div>

    <!-- The Spider-Web Global Footer (Crawler Highway) -->
    <footer class="bg-neutral-950 text-neutral-600 text-[11px] py-2 border-t border-neutral-900 text-center w-full px-4 shrink-0 z-50">
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-2">
        <a href={`/${lang}/privacy-policy`} class="hover:text-neutral-400 transition-colors">{t(lang, 'privacyPolicy')}</a>
        <a href={`/${lang}/terms-of-service`} class="hover:text-neutral-400 transition-colors">{t(lang, 'termsOfService')}</a>
        <a href={`/${lang}/contact`} class="hover:text-neutral-400 transition-colors">{t(lang, 'contactSupport')}</a>
      </div>
      <div class="flex flex-wrap justify-center gap-x-3 gap-y-1 text-[9px] text-neutral-700 max-w-2xl mx-auto uppercase">
        {langs.map(l => (
          <a href={l === 'en' ? '/' : `/${l}/`} class="hover:text-neutral-500 transition-colors">{l === 'zh-TW' ? '繁中' : l === 'zh-CN' ? '简中' : l}</a>
        ))}
      </div>
    </footer>
  </body>
</html>
