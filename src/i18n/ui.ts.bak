    'tools.default.bean.v60': 'ایتھوپیا یرگاشیفے۔',
    'tools.default.grind.aeropress': 'درمیانے سے باریک پیسنا (جیسے باریک ریت)',
    'tools.default.grind.coldbrew': 'بہت موٹا پیسنا',
    'tools.default.grind.frenchpress': 'موٹے پیس (جیسے کوشر نمک)',
    'tools.default.grind.v60': 'درمیانے سے باریک پیسنے (صرف دستی پیسنے کے لیے)',
    'tools.v60.p3': 'Hario V60 دنیا میں ہاتھ سے تیار کردہ کافی کے سب سے مشہور آلات میں سے ایک ہے۔ اس کا منفرد 60-ڈگری ٹیپرڈ ڈیزائن، بڑے قطر کے نیچے کا سوراخ اور سرپل واٹر گائیڈ بیرسٹاس کو پانی کے بہاؤ کو کنٹرول کرنے میں بہت زیادہ آزادی فراہم کرتا ہے۔ لیکن اس کی وجہ سے، V60 پانی کے انجیکشن کی تال اور استحکام پر بہت بھاری ہے۔ یہ <strong>{t(\'tools.v60.title\')} (V60 کیلکولیٹر)</strong> اور ٹائمر اس درد کے نقطہ کو حل کرنے کے لیے بنائے گئے ہیں۔',
    'grind.meta.desc': 'پیسنے والے بڑے برانڈز (Comandante C40، Timemore، Fellow Ode، Baratza Encore، Kalita) کے پیسنے والے پیمانے کو درست طریقے سے پیسنے کے سب سے بہترین پیرامیٹرز تلاش کرنے کے لیے تبدیل کریں۔',
    'grind.tooltip.turkish': 'بہت عمدہ (Türkiye)',
    'grind.tooltip.espresso': 'پتلا (اطالوی)',
    'grind.tooltip.aeropress': 'درمیانہ جرمانہ (AeroPress/V60)',
    'grind.tooltip.frenchpress': 'درمیانے موٹے (دبائیں)',
    'grind.tooltip.coldbrew': 'انتہائی گاڑھا (ٹھنڈا مرکب)',
    'grind.label.turkish': 'ترکی',
    'grind.label.espresso': 'ایسپریسو',
    'grind.label.v60': 'ہینڈ فلش',
    'grind.label.frenchpress': 'فرانسیسی پریس',
    'grind.label.coldbrew': 'ٹھنڈا مرکب',
    'grind.h2_1': 'پیسنے والے پیمانے کی تبدیلی اتنی اہم کیوں ہے؟',
    'grind.p1': 'خاص کافی کی دنیا میں، پیسنے کا سائز سب سے اہم جسمانی تغیر ہے جو نکالنے کی پیداوار کا تعین کرتا ہے۔ مختلف گرائنڈر مکمل طور پر مختلف کٹر ہیڈ جیومیٹریز (فلیٹ بررز، کونیکل بررز) اور مختلف فائن ٹیوننگ پچز استعمال کرتے ہیں، جس کا مطلب ہے کہ "کمانڈینٹ C40 کے 20 گرڈز" یقینی طور پر "ٹائممور C2 کے 20 گرڈز" کے برابر نہیں ہیں۔',
    'grind.h3_1': 'یونیورسل گرائنڈ رینجز',
    'grind.p2': 'ہمارا الگورتھم کوئی سادہ لکیری ضرب نہیں ہے، بلکہ مختلف پکنے کے طریقوں کے تحت ہر گرائنڈر کے "سویٹ پوائنٹ وقفہ" پر مبنی ایک رشتہ دار پوزیشن (فی صد انٹرپولیشن) کی تبدیلی ہے:',
    'grind.li1': '<strong>اضافی باریک</strong>: آٹے کی طرح باریک۔ خاص طور پر ترکی کی کافی (Cezve/Ibrik) کے لیے ڈیزائن کیا گیا ہے۔',
    'grind.li2': '<strong>ٹھیک</strong>: ٹیبل نمک کا سائز۔ یسپریسو کے لیے موزوں ہے، یہ 9 بار کا دباؤ بنانے کے لیے پانی کی زبردست مزاحمت فراہم کر سکتا ہے۔',
    'grind.li3': '<strong>میڈیم فائن</strong>: پیور اوور کافی (V60، کلیتا ویو) اور ایرو پریس کے لیے بہترین۔ یہ صرف 2-3 منٹ میں میٹھے اور کھٹے کا کامل توازن نکال لیتا ہے۔',
    'grind.li4': '<strong>درمیانے موٹے</strong>: موٹے سمندری نمک کی طرح۔ زیادہ بھگونے سے پیدا ہونے والی تلخی سے بچنے کے لیے فرانسیسی پریس یا کیمیکس کے لیے موزوں ہے۔',
    'grind.li5': '<strong>اضافی موٹا</strong>: ٹھنڈا مرکب طویل مدتی کم درجہ حرارت کے لیے موزوں ہے تاکہ نجاست کو کم سے کم کیا جا سکے۔',
    'grind.h3_2': 'دستبرداری اور موافقت کی تجاویز',
    'grind.p3': 'براہ کرم نوٹ کریں کہ گرائنڈر کا ایک ہی ماڈل بھی <strong>کٹر ہیڈ کے پہننے کی ڈگری</strong>، <strong>زیرو پوائنٹ سیٹنگ</strong> اور <strong>کافی بینز کی روسٹ ڈگری</strong> کی وجہ سے مختلف ہو سکتا ہے۔ اس کنورٹر کے ذریعہ فراہم کردہ قدر نقطہ آغاز ہے۔ <br/> ہم پرزور مشورہ دیتے ہیں کہ اگر پکی ہوئی کافی زیادہ کھٹی محسوس ہوتی ہے (کم نکالی گئی ہے)، تو براہ کرم 1-2 قدموں کو بہتر طریقے سے ایڈجسٹ کریں۔ اگر پکی ہوئی کافی جلی ہوئی یا کڑوی محسوس ہوتی ہے یا پانی کا بہاؤ رکا ہوا ہے (زیادہ سے زیادہ نکالنا)، تو براہ کرم 1-2 قدموں کے موٹے پیمانے کو ایڈجسٹ کریں۔',
    'grind.script.turkish': 'بہت عمدہ (ترکی)',
    'grind.script.espresso': 'باریک پاؤڈر (ایسپریسو)',
    'grind.script.aeropress': 'درمیانہ اور عمدہ (ایرو پریس)',
