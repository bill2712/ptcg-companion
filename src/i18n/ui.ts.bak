    'tools.watertemp.setup.target.light': 'Light (95℃)',
    'tools.watertemp.setup.kettle': 'Kettle Material',
    'tools.watertemp.setup.kettle.stainless': 'Stainless Steel',
    'tools.watertemp.setup.kettle.ceramic': 'Ceramic',
    'tools.watertemp.setup.kettle.glass': 'Glass',
    'tools.watertemp.setup.esttime': 'Estimated Wait Time',
    'tools.watertemp.setup.startbtn': 'Start Cooling Timer',
    'tools.watertemp.cd.cancel': 'Cancel Timer',
    'tools.watertemp.cd.target': 'Target Temp',
    'tools.watertemp.cd.current': 'Current Temp',
    'tools.watertemp.cd.hint': 'Keep the kettle lid open for natural cooling. A chime will play when ready.',
    'tools.watertemp.cd.info': 'Info',
    'tools.watertemp.cd.info.ambient': 'Ambient',
    'tools.watertemp.cd.info.start': 'Starting',
    'tools.watertemp.cd.info.material': 'Material',
    'tools.watertemp.jsonld.name': 'Water Temp Predictor',
    'tools.watertemp.jsonld.desc': 'Accurately predict water cooling time.',
    'tools.watertemp.meta.title': 'Water Temp Predictor | Barista Flow',
    'tools.watertemp.meta.desc': 'Use Newton\'s Law of Cooling to predict your kettle\'s temperature drop.',
    'tools.watertemp.h2': 'Why Predict Water Temperature?',
    'tools.watertemp.p1': 'Water temperature is critical for extraction. Boiling water can cause over-extraction and bitterness.',
    'tools.watertemp.p2': 'Using a thermometer every time disrupts workflow.',
    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'Ручной чайник из нержавеющей стали',
    'tools.watertemp.script.impossible': 'Невозможно достичь',
    'tools.bean.faq.1.q': 'Каков процесс «дегазации» кофейных зерен?',
    'tools.bean.faq.1.a': 'В процессе обжарки кофейные зерна выделяют большое количество углекислого газа, который задерживается в клеточной структуре. Свежеобжаренные кофейные зерна очень сильно выделяют газы. При немедленном заваривании большое количество пузырьков будет препятствовать контакту горячей воды с кофейным порошком, что приведет к недостаточной экстракции и слабому вкусу. Так называемое «выращивание зерен» — это процесс выдерживания кофейных зерен в течение нескольких {t(\'tools.bean.status.days2\')}, чтобы позволить избытку углекислого газа естественным образом высвободиться и достичь наилучшего баланса вкуса кофе.',
    'tools.bean.faq.2.q': 'Как правильно хранить кофейные зерна, чтобы сохранить свежесть?',
    'tools.bean.faq.2.a': 'Три врага сохранения кофейных зерен: кислород, свет и влага. Лучший способ хранения кофейных зерен — поместить их в герметичный пакет с односторонним выпускным клапаном или непрозрачную вакуумную банку в прохладном сухом шкафу без прямых солнечных лучей. Никогда не помещайте в холодильник часто используемые кофейные зерна, так как влага, образующаяся из-за разницы температур при открытии и закрытии холодильника, приведет к тому, что кофейные зерна быстро станут влажными и впитают запахи.',
    'tools.bean.faq.3.a': 'Да, но есть строгие условия. Если вы покупаете большое количество кофейных зерен, которые не можете съесть в течение месяца, вы можете «разделить» их на небольшие порции для одной заварки (например, в пробирки или вакуумные пакеты) и поместить глубоко в морозильную камеру. Когда захотите заварить, просто достаньте необходимое количество «лед снимать не надо» и сразу измельчите. Будьте осторожны и не кладите несколько раз весь пакет зерен в морозильную камеру, так как это полностью испортит вкус кофе.',
    'tools.bean.jsonld.name': 'Калькулятор кофейных зерен и свежести (Bean Freshness Calculator)',
    'tools.bean.jsonld.desc': 'На основании даты обжарки и степени обжарки кофейных зерен он может точно рассчитать, находится ли кофе в периоде золотого вкуса, и предоставить профессиональные рекомендации по настройке параметров заваривания.',
    'tools.bean.meta.title': 'Калькулятор выращивания и свежести кофейных зерен | Прогноз периода золотого вкуса | Бариста Флоу',
    'tools.bean.meta.desc': 'Хорошо ли растут ваши кофейные зерна? Введите дату обжарки, и наш интеллектуальный компьютер сообщит вам, находятся ли кофейные зерна в настоящее время в периоде истощения, периоде золотистого вкуса или периоде упадка, и даст вам лучшие рекомендации по завариванию.',
    'tools.bean.title': 'Калькулятор кофейных зерен и свежести',
    'tools.bean.subtitle': 'Освойте лучшее время экстракции. Введите дату и степень обжарки, чтобы понять текущий вкус и условия выделения газов из ваших кофейных зерен.',
    'tools.bean.label.date': '{t(\'tools.bean.setup.date\')} в оболочке',
    'tools.bean.label.level': 'Уровень обжарки',
    'tools.bean.opt.light': 'Легкая обжарка – более длительный период выращивания.',
    'tools.bean.opt.medium': 'Средняя обжарка – стандартная',
    'tools.bean.opt.dark': 'Dark Roast – выпейте как можно скорее.',
    'tools.bean.status.passed': 'День выпечки прошел',
    'tools.bean.status.days': 'небо',
    'tools.bean.status.current': 'Текущий статус вкуса',
    'tools.bean.status.golden': 'период золотого вкуса',
    'tools.bean.status.golden.desc': 'Вытяжка завершена, и развитие вкуса достигло своего пика. Сейчас самый вкусный момент для этого пакетика с кофейными зернами.',
    'tools.bean.graph.title': 'Кривая жизненного цикла кофейных зерен',
    'tools.bean.graph.phase1': 'период истощения',
    'tools.bean.graph.phase3': 'зрелый стабильный период',
    'tools.bean.graph.phase4': 'период снижения вкуса',
    'tools.bean.advice.title': 'Предложения по стратегии пивоварения',
    'tools.bean.empty.prompt': 'Для расчета выберите дату обжарки на упаковке.',
    'tools.bean.faq.title': 'Часто задаваемые вопросы о кофейных зернах',
    'tools.bean.faq.3.q': 'Можно ли заморозить кофейные зерна в холодильнике?',
    'tools.bean.faq.1.a_text': 'В процессе обжарки кофейные зерна выделяют большое количество углекислого газа, который задерживается в клеточной структуре. Свежеобжаренные кофейные зерна сильно выделяют газы. При немедленном заваривании большое количество пузырьков будет препятствовать контакту горячей воды с кофейным порошком, что приведет к недостаточной экстракции и слабому вкусу (то есть к эффекту обычного водного канала). Так называемое «выращивание зерен» — это физический процесс, при котором кофейные зерна оставляют отдыхать на несколько дней, чтобы позволить избытку углекислого газа естественным образом высвободиться и достичь наилучшего баланса вкуса кофе.',

    'tools.default.bean.aeropress': 'Гватемала Уиуитнанго',
    'tools.default.bean.coldbrew': 'Бобовые смеси из темного жареного шоколада',
    'tools.default.bean.frenchpress': 'Колумбия промыта',
    'tools.default.bean.v60': 'Эфиопия Йиргачеффе',
    'tools.default.grind.aeropress': 'Помол от среднего до мелкого (например, мелкий песок)',
    'tools.default.grind.coldbrew': 'Очень грубый помол',
    'tools.default.grind.frenchpress': 'Грубого помола (как кошерная соль)',
    'tools.default.grind.v60': 'Средне-тонкий помол (только для ручного помола)',
    'tools.v60.p3': 'Hario V60 — один из самых популярных в мире аппаратов для приготовления кофе вручную. Его уникальная коническая конструкция под углом 60 градусов, нижнее отверстие большого диаметра и спиральная направляющая для воды дают бариста высокую степень свободы в контроле потока воды. Но из-за этого V60 очень тяжел по ритмичности и стабильности впрыска воды. Этот <strong>{t(\'tools.v60.title\')} (калькулятор V60)</strong> и таймер предназначены для решения этой проблемы.',
    'grind.meta.desc': 'Точно преобразуйте масштабы помола кофемолок основных марок (Comandante C40, Timemore, Fellow Ode, Baratza Encore, Kalita), чтобы найти наиболее идеальные параметры пивоварения.',
    'grind.tooltip.turkish': 'Очень хорошо (Türkiye)',
    'grind.tooltip.espresso': 'тонкий (итальянский)',
    'grind.tooltip.aeropress': 'Средне-мелкий (АэроПресс/V60)',
    'grind.tooltip.frenchpress': 'среднегрубый (пресс)',
    'grind.tooltip.coldbrew': 'Чрезвычайно густой (колд брю)',
    'grind.label.turkish': 'Турция',
    'grind.label.espresso': 'Эспрессо',
    'grind.label.v60': 'ручной смыв',
    'grind.label.frenchpress': 'Французская пресса',
    'grind.label.coldbrew': 'холодный напиток',
    'grind.h2_1': 'Почему преобразование окалины так важно?',
    'grind.p1': 'В мире спешелти кофе размер помола является наиболее важной физической переменной, определяющей выход экстракции. В разных шлифовальных станках используется совершенно разная геометрия режущих головок (плоские борфрезы, конические борфрезы) и разный шаг точной настройки, что означает, что «20 решеток Comandante C40» определенно не равны «20 решеткам Timemore C2».',
    'grind.h3_1': 'Универсальные диапазоны измельчения',
    'grind.p2': 'Наш алгоритм представляет собой не простое линейное умножение, а преобразование относительного положения (процентная интерполяция), основанное на «интервале точки сладости» каждой кофемолки при различных методах заваривания:',
    'grind.li1': '<strong>Очень мелкая</strong>: тонкая, как мука. Специально разработан для турецкого кофе (Джезве/Ибрик).',
    'grind.li2': '<strong>Хорошо</strong>: размер поваренной соли. Подходит для эспрессо и обеспечивает отличную водостойкость, создавая давление до 9 бар.',
    'grind.li3': '<strong>Средне-высокое</strong>: лучше всего подходит для пуровера (V60, Kalita Wave) и AeroPress. Он извлекает идеальный баланс сладкого и кислого всего за 2-3 минуты.',
    'grind.li4': '<strong>Средне-крупная</strong>: Как крупная морская соль. Подходит для френч-пресса или кемекса, чтобы избежать горечи, вызванной чрезмерным замачиванием.',
    'grind.li5': '<strong>Extra Coarse</strong>: Колд Брю подходит для длительного замачивания при низкой температуре, чтобы свести к минимуму извлечение примесей.',
    'grind.h3_2': 'Отказ от ответственности и предложения по настройке',
    'grind.p3': 'Обратите внимание, что даже одна и та же модель кофемолки может отличаться в зависимости от <strong>степени износа режущей головки</strong>, <strong>настройки нулевой точки</strong> и <strong>степени обжарки кофейных зерен</strong>. Значение, предоставленное этим преобразователем, является отправной точкой. <br/> Мы настоятельно рекомендуем, если заваренный кофе кажется слишком кислым (недостаточно экстрагированным), отрегулируйте шкалу на 1–2 шага тоньше; Если заваренный кофе кажется подгоревшим или горьким или поток воды застаивается (чрезмерная экстракция), отрегулируйте шкалу на 1–2 шага крупнее.',
    'grind.script.turkish': 'Очень хорошо (турецкий)',
    'grind.script.espresso': 'Мелкий порошок (Эспрессо)',
    'grind.script.aeropress': 'Средний и мелкий (АэроПресс)',
    'grind.script.v60': 'Средний (руководство V60)',
    'grind.script.frenchpress': 'средней грубости (френч-пресс)',
    'grind.script.coldbrew': 'Очень густой (холодный кофе)',

    'history.meta.title': 'Моя история пивоварения | Бариста Флоу',
    'history.meta.desc': 'Просматривайте все свои записи о приготовлении кофе и дегустации вкусов, чтобы создать свой собственный журнал кофе.',
    'history.title': 'Моя история пивоварения',
