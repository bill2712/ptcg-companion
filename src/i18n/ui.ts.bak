  "de": {
    'about.offer.l2.title': 'Knowledge Base',
    'about.offer.l3.title': 'Global Community',
    'about.vision.p2': 'is to build the world\'s most professional and easy-to-use coffee brewing tool platform, allowing everyone from pour-over beginners to seasoned baristas to find answers to elevate their extraction quality.',
    'terms.meta.title': 'Terms of Service | Barista Flow',
    'terms.meta.desc': 'Barista Flow Terms of Service. Regulations on website usage, intellectual property, and disclaimers.',
    'terms.intro': 'Welcome to Barista Flow ("the Website"). By browsing, accessing, or using any tools and content provided by this Website, you fully agree to and accept the following terms of service. If you do not agree with any part of these terms, please do not use this Website.',
    'terms.s1.p1': 'Barista Flow provides free online coffee brewing timers, parameter calculation tools, and knowledge articles related to coffee science. This website is intended for personal, non-commercial reference and assistance.',
    'terms.s2.title': 'Intellectual Property',
    'terms.s2.p1': 'All content on this Website, including but not limited to text, logos, images, charts, application code, UI design, and architecture, is the property of the Barista Flow team or has been legally authorized for use.',
    'terms.s2.l1': 'Without our prior written permission, you may not copy, modify, distribute, publish, display, or use the content of this Website for any commercial purposes.',
    'terms.s2.l2': 'You may share links to this Website for personal learning purposes (for example, using our "Share this recipe" feature).',
    'terms.s3.p1': 'All coffee parameters, instructional articles, and timing tools provided by this Website are provided "as is." While we strive for scientific accuracy, coffee brewing is affected by many physical variables (such as water quality, bean type, temperature, etc.).',
    'terms.s3.l1': 'We make no express or implied warranties regarding the absolute accuracy, completeness, or applicability of the content on this Website.',
    'terms.s3.l2': 'Barista Flow is not responsible for any direct, indirect, or incidental losses (including but not limited to the loss of coffee beans or damage to equipment) caused by using the tools on this Website or relying on the information on this Website.',
    'terms.s4.title': 'User Conduct',
    'terms.s4.p1': 'When using this Website, you agree to comply with all applicable laws and regulations, and you must not:',
    'terms.s4.l1': 'Use this Website in any way that could cause the Website\'s server or network to be overloaded, damaged, or interrupted (e.g., DDoS attacks or malicious scraping).',
    'terms.s4.l2': 'Attempt to gain unauthorized access to the Website\'s backend system or source code.',
    'terms.s4.l3': 'Use this Website to engage in any illegal or fraudulent activities.',
    'terms.s5.title': 'Third-Party Services and Ads',
    'terms.s5.p1': 'This Website may contain links to third-party websites or display third-party advertisements (such as Google AdSense). We have no control over the content and privacy policies of these third-party websites. Any risks arising from clicking on ads or external links are the sole responsibility of the user.',
    'terms.s6.title': 'Modification and Termination',
    'terms.s6.p1': 'We reserve the right to modify, suspend, or terminate the services of this Website and these Terms of Service at any time without prior notice. Your continued use of this Website constitutes your acceptance of any modified terms.',

    'tools.watertemp.title': 'Physics-Based Water Temp Predictor',
    'tools.watertemp.subtitle': 'Uses Newton\'s Law of Cooling to calculate exactly how long to wait for your boiling water to reach the perfect brewing temperature.',
    'tools.watertemp.setup.title': 'Parameters',
    'tools.watertemp.setup.ambient': 'Ambient Temp',
    'tools.watertemp.setup.ambient.cold': 'Cold',
    'tools.watertemp.setup.ambient.hot': 'Hot',
    'tools.watertemp.setup.target': 'Target Temp',
    'tools.watertemp.setup.target.dark': 'Dark (85℃)',
    'tools.watertemp.setup.target.light': 'Light (95℃)',
    'tools.watertemp.setup.kettle': 'Kettle Material',
    'tools.watertemp.setup.kettle.stainless': 'Stainless Steel',
    'tools.watertemp.setup.kettle.ceramic': 'Ceramic',
    'tools.watertemp.setup.kettle.glass': 'Glass',
    'tools.watertemp.setup.esttime': 'Estimated Wait Time',
    'tools.watertemp.setup.startbtn': 'Start Cooling Timer',
    'tools.watertemp.cd.cancel': 'Cancel Timer',
    'tools.watertemp.cd.target': 'Target Temp',
    'tools.watertemp.cd.current': 'Current Temp',
    'tools.watertemp.cd.hint': 'Keep the kettle lid open for natural cooling. A chime will play when ready.',
    'tools.watertemp.cd.info': 'Info',
    'tools.watertemp.cd.info.ambient': 'Ambient',
    'tools.watertemp.cd.info.start': 'Starting',
    'tools.watertemp.cd.info.material': 'Material',
    'tools.watertemp.jsonld.name': 'Water Temp Predictor',
    'tools.watertemp.jsonld.desc': 'Accurately predict water cooling time.',
    'tools.watertemp.meta.title': 'Water Temp Predictor | Barista Flow',
    'tools.watertemp.meta.desc': 'Use Newton\'s Law of Cooling to predict your kettle\'s temperature drop.',
    'tools.watertemp.h2': 'Why Predict Water Temperature?',
    'tools.watertemp.p1': 'Water temperature is critical for extraction. Boiling water can cause over-extraction and bitterness.',
    'tools.watertemp.p2': 'Using a thermometer every time disrupts workflow.',
    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'Handbrühkessel aus Edelstahl',
    'tools.watertemp.script.impossible': 'Nicht erreichbar',
    'tools.bean.faq.1.q': 'Was ist der „Entgasungsprozess“ von Kaffeebohnen?',
    'tools.bean.faq.1.a': 'Während des Röstvorgangs produzieren Kaffeebohnen große Mengen Kohlendioxid, das in der Zellstruktur eingeschlossen wird. Frisch geröstete Kaffeebohnen entgasen sehr stark. Beim sofortigen Brühen verhindert eine große Anzahl von Blasen den Kontakt zwischen heißem Wasser und Kaffeepulver, was zu einer unzureichenden Extraktion und einem schwachen Geschmack führt. Bei der sogenannten „Bohnenaufzucht“ werden Kaffeebohnen einige {t(\'tools.bean.status.days2\')} stehen gelassen, damit überschüssiges Kohlendioxid auf natürliche Weise freigesetzt werden kann und die beste Ausgewogenheit des Kaffeegeschmacks erreicht wird.',
    'tools.bean.faq.2.q': 'Wie lagert man Kaffeebohnen richtig, um die Frische zu bewahren?',
    'tools.bean.faq.2.a': 'Die drei Feinde der Kaffeebohnenkonservierung sind: Sauerstoff, Licht und Feuchtigkeit. Die beste Art und Weise, Kaffeebohnen aufzubewahren, besteht darin, sie in einem versiegelten Beutel mit Einweg-Auslassventil oder einem undurchsichtigen Vakuumbehälter in einem kühlen, trockenen Schrank ohne direkte Sonneneinstrahlung aufzubewahren. Legen Sie niemals häufig verwendete Kaffeebohnen in den Kühlschrank, da die durch den Temperaturunterschied beim Öffnen und Schließen des Kühlschranks entstehende Feuchtigkeit dazu führt, dass die Kaffeebohnen schnell feucht werden und Gerüche annehmen.',
    'tools.bean.faq.3.a': 'Ja, aber es gelten strenge Auflagen. Wenn Sie eine große Menge Kaffeebohnen kaufen, die Sie nicht innerhalb eines Monats aufbrauchen können, können Sie diese in kleine Einzelbrühportionen (z. B. Reagenzgläser oder Vakuumbeutel) „portionieren“ und tief in den Gefrierschrank stellen. Wenn Sie den Kaffee aufbrühen möchten, entnehmen Sie einfach die erforderliche Menge, ohne dass das Eis entfernt werden muss, und mahlen Sie sie sofort. Achten Sie darauf, dass Sie nicht immer wieder die ganze Tüte Bohnen in den Gefrierschrank legen und wieder herausnehmen, da dies den Geschmack des Kaffees völlig zerstört.',
    'tools.bean.jsonld.name': 'Rechner für Kaffeebohnen und Frische (Bean Freshness Calculator)',
    'tools.bean.jsonld.desc': 'Basierend auf dem Röstdatum und dem Röstgrad der Kaffeebohnen kann genau berechnet werden, ob sich die Kaffeebohnen in der goldenen Geschmacksphase befinden, und professionelle Vorschläge zur Anpassung der Brühparameter liefern.',
    'tools.bean.meta.title': 'Kaffeebohnen-Anbau- und Frische-Rechner | Vorhersage der goldenen Geschmacksperiode | Barista Flow',
    'tools.bean.meta.desc': 'Wachsen Ihre Kaffeebohnen gut? Geben Sie das Röstdatum ein, und unser intelligenter Computer sagt Ihnen, ob sich die Kaffeebohnen gerade in der Erschöpfungsphase, der Phase des goldenen Aromas oder der Abklingphase befinden, und gibt Ihnen die besten Brühvorschläge.',
    'tools.bean.title': 'Rechner für Kaffeebohnen und Frische',
    'tools.bean.subtitle': 'Meistern Sie die beste Extraktionszeit. Geben Sie das Röstdatum und den Röstgrad ein, um den aktuellen Geschmack und die Ausgasungsbedingungen Ihrer Kaffeebohnen zu verstehen.',
    'tools.bean.label.date': '{t(\'tools.bean.setup.date\')} auf dem Wrapper',
    'tools.bean.label.level': 'Röstgrad',
    'tools.bean.opt.light': 'Leichte Röstung – Längere Anbaudauer',
    'tools.bean.opt.medium': 'Mittlere Röstung – Standard',
    'tools.bean.opt.dark': 'Dark Roast – so schnell wie möglich trinken',
    'tools.bean.status.passed': 'Der Backtag ist vorbei',
    'tools.bean.status.days': 'Himmel',
    'tools.bean.status.current': 'Aktueller Geschmacksstatus',
    'tools.bean.status.golden': 'goldene Geschmacksperiode',
    'tools.bean.status.golden.desc': 'Der Auspuff ist abgeschlossen und die Geschmacksentwicklung hat ihren Höhepunkt erreicht. Jetzt ist der köstlichste Moment für diese Tüte Kaffeebohnen.',
    'tools.bean.graph.title': 'Lebenszykluskurve einer Kaffeebohne',
    'tools.bean.graph.phase1': 'Erschöpfungszeitraum',
    'tools.bean.graph.phase3': 'reife stabile Periode',
    'tools.bean.graph.phase4': 'Zeitraum des Geschmacksrückgangs',
    'tools.bean.advice.title': 'Vorschläge für Braustrategien',
    'tools.bean.empty.prompt': 'Zur Berechnung wählen Sie bitte das Röstdatum auf der Packung aus',
    'tools.bean.faq.title': 'Häufig gestellte Fragen zu Kaffeebohnen',
    'tools.bean.faq.3.q': 'Kann ich Kaffeebohnen im Kühlschrank einfrieren?',
    'tools.bean.faq.1.a_text': 'Während des Röstvorgangs produzieren Kaffeebohnen große Mengen Kohlendioxid, das in der Zellstruktur eingeschlossen wird. Frisch geröstete Kaffeebohnen sind stark ausgasend. Beim sofortigen Brühen verhindert eine große Anzahl von Blasen den Kontakt zwischen heißem Wasser und Kaffeepulver, was zu einer unzureichenden Extraktion und einem schwachen Geschmack führt (d. h. der gemeinsame Wasserkanaleffekt). Das sogenannte „Bean Raising“ ist ein physikalischer Prozess, bei dem Kaffeebohnen mehrere Tage ruhen, damit überschüssiges Kohlendioxid auf natürliche Weise freigesetzt werden kann und die beste Ausgewogenheit des Kaffeegeschmacks erreicht wird.',

    'tools.default.bean.aeropress': 'Guatemala Huihuitnango',
    'tools.default.bean.coldbrew': 'Gemischte Bohnen aus dunkler gerösteter Schokolade',
    'tools.default.bean.frenchpress': 'Kolumbien gewaschen',
    'tools.default.bean.v60': 'Äthiopien Yirgacheffe',
    'tools.default.grind.aeropress': 'Mittlerer bis feiner Mahlgrad (z. B. feiner Sand)',
    'tools.default.grind.coldbrew': 'Sehr grober Mahlgrad',
    'tools.default.grind.frenchpress': 'Grob gemahlen (wie koscheres Salz)',
    'tools.default.grind.v60': 'Mittlerer bis feiner Mahlgrad (nur für manuellen Mahlvorgang)',
    'tools.v60.p3': 'Hario V60 ist eines der beliebtesten handgebrühten Kaffeegeräte der Welt. Sein einzigartiges, sich verjüngendes 60-Grad-Design, das Bodenloch mit großem Durchmesser und die spiralförmige Wasserführung geben Baristas ein hohes Maß an Freiheit bei der Steuerung des Wasserflusses. Aus diesem Grund ist der V60 jedoch sehr stark vom Rhythmus und der Stabilität der Wassereinspritzung abhängig. Dieses <strong>{t(\'tools.v60.title\')} (V60-Rechner)</strong> und der Timer sollen dieses Problem lösen.',
    'grind.meta.desc': 'Konvertieren Sie die Mahlskalen der wichtigsten Mühlenmarken (Comandante C40, Timemore, Fellow Ode, Baratza Encore, Kalita) genau, um die perfektesten Brühparameter zu finden.',
    'grind.tooltip.turkish': 'Sehr gut (Türkiye)',
    'grind.tooltip.espresso': 'dünn (italienisch)',
    'grind.tooltip.aeropress': 'Mittelfein (AeroPress/V60)',
    'grind.tooltip.frenchpress': 'mittelgrob (Presse)',
    'grind.tooltip.coldbrew': 'Extrem dickflüssig (Cold Brew)',
    'grind.label.turkish': 'Türkei',
    'grind.label.espresso': 'Espresso',
    'grind.label.v60': 'Handspülung',
    'grind.label.frenchpress': 'Französische Presse',
    'grind.label.coldbrew': 'kaltes Gebräu',
    'grind.h2_1': 'Warum ist die Umrechnung des Mahlgrads so wichtig?',
    'grind.p1': 'In der Welt des Spezialitätenkaffees ist der Mahlgrad die kritischste physikalische Variable, die die Extraktionsausbeute bestimmt. Verschiedene Schleifmaschinen verwenden völlig unterschiedliche Schneidkopfgeometrien (flache Grate, konische Grate) und unterschiedliche Feinabstimmungsschritte, was bedeutet, dass „Comandante C40 mit 20 Gittern“ definitiv nicht mit „Timemore C2 mit 20 Gittern“ gleichzusetzen ist.',
    'grind.h3_1': 'Universelle Mahlbereiche',
    'grind.p2': 'Bei unserem Algorithmus handelt es sich nicht um eine einfache lineare Multiplikation, sondern um eine relative Positionskonvertierung (prozentuale Interpolation), die auf dem „Sweet-Point-Intervall“ jeder Mühle bei unterschiedlichen Brühmethoden basiert:',
    'grind.li1': '<strong>Extrafein</strong>: So fein wie Mehl. Speziell für türkischen Kaffee (Cezve/Ibrik) entwickelt.',
    'grind.li2': '<strong>Fein</strong>: Die Größe von Speisesalz. Es ist für Espresso geeignet und bietet eine hohe Wasserbeständigkeit, um einen Druck von 9 Bar aufzubauen.',
    'grind.li3': '<strong>Mittelfein</strong>: Am besten für Kaffee zum Übergießen (V60, Kalita Wave) und AeroPress. Es extrahiert die perfekte Balance zwischen süß und sauer in nur 2-3 Minuten.',
    'grind.li4': '<strong>Mittelgrob</strong>: Wie grobes Meersalz. Geeignet für French Press oder Chemex, um Bitterkeit durch übermäßiges Einweichen zu vermeiden.',
    'grind.li5': '<strong>Extra grob</strong>: Cold Brew, geeignet für langfristiges Einweichen bei niedriger Temperatur, um die Extraktion von Verunreinigungen zu minimieren.',
    'grind.h3_2': 'Haftungsausschluss und Optimierungsvorschläge',
    'grind.p3': 'Bitte beachten Sie, dass selbst bei gleichem Mühlenmodell Abweichungen aufgrund des <strong>Verschleißgrades des Messerkopfes</strong>, der <strong>Nullpunkteinstellung</strong> und des <strong>Röstgrades der Kaffeebohnen</strong> auftreten können. Der von diesem Konverter bereitgestellte Wert ist der Ausgangspunkt. <br/> Wir empfehlen dringend, die Skala um 1–2 Stufen feiner einzustellen, wenn sich der gebrühte Kaffee zu sauer anfühlt (zu wenig extrahiert). Wenn sich der gebrühte Kaffee verbrannt oder bitter anfühlt oder der Wasserfluss stagniert (Überextraktion), stellen Sie die Skala bitte 1-2 Schritte gröber ein.',
    'grind.script.turkish': 'Sehr gut (Türkisch)',
    'grind.script.espresso': 'Feines Pulver (Espresso)',
