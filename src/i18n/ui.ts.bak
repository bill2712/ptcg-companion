    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'ステンレス製の手淹れケトル',
    'tools.watertemp.script.impossible': '達成できません',
    'tools.bean.faq.1.q': 'コーヒー豆の「脱気」とは何ですか？',
    'tools.bean.faq.1.a': '焙煎プロセス中に、コーヒー豆は細胞構造内に閉じ込められた大量の二酸化炭素を生成します。焙煎したてのコーヒー豆は非常に激しくガスを放出します。すぐに淹れると、泡が多くなりお湯とコーヒー粉が触れなくなり、抽出が不十分になり風味が弱くなってしまいます。いわゆる「豆育て」とは、コーヒー豆を数日間 {t(\'tools.bean.status.days2\')} 放置して、過剰な二酸化炭素を自然に放出させ、コーヒーの風味の最適なバランスを実現するプロセスです。',
    'tools.bean.faq.2.q': 'コーヒー豆の鮮度を保つための正しい保存方法は？',
    'tools.bean.faq.2.a': 'コーヒー豆の保存の3大敵は、酸素、光、湿気です。コーヒー豆を保管する最良の方法は、一方向排気バルブを備えた密封袋または不透明な真空瓶にコーヒー豆を入れ、直射日光の当たらない乾燥した涼しい戸棚に置くことです。頻繁に使用するコーヒー豆は、冷蔵庫の開閉時の温度差により発生する湿気により、すぐに湿気を帯びて臭いが移りますので、冷蔵庫には絶対に置かないでください。',
    'tools.bean.faq.3.a': 'はい、ただし厳しい条件があります。 1 か月以内に飲みきれない大量のコーヒー豆を購入した場合は、一度に淹れるための小さな小分け (試験管や真空バッグなど) に「小分け」し、冷凍庫の奥深くに入れておくことができます。淹れたいときに「氷を外す必要がなく」必要な量を取り出して、すぐに挽くだけ。豆の袋ごと冷凍庫に何度も出し入れすると、コーヒーの風味が完全に損なわれてしまうので注意してください。',
    'tools.bean.jsonld.name': 'コーヒー豆と鮮度計算ツール (Bean Freshness Calculator)',
    'tools.bean.jsonld.desc': 'コーヒー豆の焙煎日と焙煎度合いに基づいて、黄金フレーバー期間にあるかどうかを正確に計算し、プロによる抽出パラメータ調整の提案を提供します。',
    'tools.bean.meta.title': 'コーヒー豆の栽培と鮮度の計算 |ゴールデンフレーバー期間予測 |バリスタフロー',
    'tools.bean.meta.desc': 'あなたのコーヒー豆は順調に成長していますか？焙煎日を入力すると、当社のインテリジェントコンピューターがコーヒー豆が現在枯渇期、黄金フレーバー期、衰退期のいずれにあるかを判断し、最適な淹れ方を提案します。',
    'tools.bean.title': 'コーヒー豆と鮮度の計算ツール',
    'tools.bean.subtitle': 'ベストな抽出時間をマスターしましょう。焙煎日と焙煎度を入力すると、コーヒー豆の現在の風味とガスの放出状態がわかります。',
    'tools.bean.label.date': 'ラッパーの {t(\'tools.bean.setup.date\')}',
    'tools.bean.label.level': 'ローストレベル',
    'tools.bean.opt.light': '浅煎り - 栽培期間が長い',
    'tools.bean.opt.medium': 'ミディアムロースト - スタンダード',
    'tools.bean.opt.dark': 'ダークロースト - できるだけ早くお飲みください',
    'tools.bean.status.passed': 'パンの日が過ぎました',
    'tools.bean.status.days': '空',
    'tools.bean.status.current': '現在のフレーバーのステータス',
    'tools.bean.status.golden': '黄金風味の時代',
    'tools.bean.status.golden.desc': '排気が完了し、フレーバー開発は最高潮に達しました。この袋のコーヒー豆は今が一番おいしい時期です。',
    'tools.bean.graph.title': 'コーヒー豆のライフサイクル曲線',
    'tools.bean.graph.phase1': '枯渇期間',
    'tools.bean.graph.phase3': '成熟した安定期',
    'tools.bean.graph.phase4': '風味低下期',
    'tools.bean.advice.title': '醸造戦略の提案',
    'tools.bean.empty.prompt': '計算するにはパッケージに記載されている焙煎日を選択してください',
    'tools.bean.faq.title': 'コーヒー豆に関するよくある質問',
    'tools.bean.faq.3.q': 'コーヒー豆を冷蔵庫で冷凍しても大丈夫ですか？',
    'tools.bean.faq.1.a_text': '焙煎プロセス中に、コーヒー豆は細胞構造内に閉じ込められた大量の二酸化炭素を生成します。焙煎したてのコーヒー豆は非常にガスが発生します。すぐに淹れると、多量の泡によりお湯とコーヒー粉の接触が妨げられ、抽出が不十分になり風味が弱くなってしまいます（いわゆる水路効果）。いわゆる「豆上げ」とは、コーヒー豆を数日間寝かせる物理的なプロセスで、過剰な二酸化炭素を自然に放出させ、コーヒーの風味の最適なバランスを実現します。',

    'tools.default.bean.aeropress': 'グアテマラ ウィウィトナンゴ',
    'tools.default.bean.coldbrew': 'ダークローストチョコレートミックスビーンズ',
    'tools.default.bean.frenchpress': 'コロンビアウォッシュ済み',
    'tools.default.bean.v60': 'エチオピア イルガチェフェ',
    'tools.default.grind.aeropress': '中〜細粉砕（細砂など）',
    'tools.default.grind.coldbrew': '非常に粗い挽き方',
    'tools.default.grind.frenchpress': '粗く粉砕したもの（コーシャーソルトなど）',
    'tools.default.grind.v60': '中〜細研削（手研ぎ専用）',
    'tools.v60.p3': 'ハリオ V60 は、世界で最も人気のある手淹れコーヒー器具の 1 つです。独自の60度テーパーデザイン、大口径底穴、スパイラルウォーターガイドにより、バリスタに高い自由度の水流コントロールを提供します。しかし、そのせいでV60は注水のリズムと安定性に非常に負担がかかってしまいます。この <strong>{t(\'tools.v60.title\')} (V60 電卓)</strong> とタイマーは、この問題点を解決するように設計されています。',
    'grind.meta.desc': '主要ブランドのグラインダー (Comandante C40、Timemore、Fellow Ode、Baratza Encore、Kalita) の粉砕スケールを正確に変換して、最も完璧な醸造パラメーターを見つけます。',
    'grind.tooltip.turkish': 'とても良い (トゥルキエ)',
    'grind.tooltip.espresso': '細い（イタリア人）',
    'grind.tooltip.aeropress': '中細目（エアロプレス/V60）',
    'grind.tooltip.frenchpress': '中粗（プレス）',
    'grind.tooltip.coldbrew': '極濃（水出し）',
    'grind.label.turkish': 'トゥルキエ',
    'grind.label.espresso': 'エスプレッソ',
    'grind.label.v60': 'ハンドフラッシュ',
    'grind.label.frenchpress': 'フレンチプレス',
    'grind.label.coldbrew': '冷たいビール',
    'grind.h2_1': 'グラインドスケールの変換がそれほど重要なのはなぜですか?',
    'grind.p1': 'スペシャルティ コーヒーの世界では、粉砕サイズが抽出収量を決定する最も重要な物理的変数です。グラインダーが異なれば、使用するカッターヘッドの形状 (フラット バー、コニカル バー) や微調整ピッチも異なります。つまり、「Comandante C40 の 20 グリッド」は「Timemore C2 の 20 グリッド」と明らかに同じではありません。',
    'grind.h3_1': 'ユニバーサル粉砕範囲',
    'grind.p2': '私たちのアルゴリズムは単純な線形乗算ではなく、さまざまな抽出方法における各グラインダーの「スイート ポイント間隔」に基づいた相対位置 (パーセンテージ補間) 変換です。',
    'grind.li1': '<strong>極細</strong>: 小麦粉と同じくらい細かいです。トルココーヒー (ジェズベ/イブリク) 用に特別に設計されています。',
    'grind.li2': '<strong>細かい</strong>: 食卓塩のサイズ。エスプレッソに適しており、9 Bar の圧力を構築するために優れた耐水性を提供できます。',
    'grind.li3': '<strong>中細目</strong>: ドリップコーヒー (V60、Kalita Wave) および AeroPress に最適です。わずか2～3分で甘味と酸味の絶妙なバランスが抽出されます。',
    'grind.li4': '<strong>中粗め</strong>: 粗い海塩のようなもの。浸しすぎによる苦味を避けるため、フレンチプレスまたはケメックスに適しています。',
    'grind.li5': '<strong>極粗粒</strong>: 不純物の抽出を最小限に抑えるため、低温での長期浸漬に適したコールドブリューです。',
    'grind.h3_2': '免責事項と微調整の提案',
    'grind.p3': '同じモデルのグラインダーであっても<strong>カッターヘッドの磨耗度合い</strong>や<strong>ゼロ点設定</strong>や<strong>コーヒー豆の焙煎度合い</strong>などにより変化する場合がありますので、予めご了承ください。このコンバータによって提供される値が開始点となります。 <br/> 淹れたコーヒーが酸っぱすぎる（抽出不足）と感じる場合は、スケールを 1 ～ 2 段階細かく調整することを強くお勧めします。淹れたコーヒーに焦げや苦みを感じたり、水の流れが滞る（抽出過多）場合は、目盛を1～2段階粗く調整してください。',
    'grind.script.turkish': 'とてもいいです (トルコ語)',
    'grind.script.espresso': '微粉末（エスプレッソ）',
    'grind.script.aeropress': '中細 (AeroPress)',
    'grind.script.v60': '中（V60マニュアル）',
    'grind.script.frenchpress': '中粗目（フレンチプレス）',
    'grind.script.coldbrew': '極濃（水出しコーヒー）',

