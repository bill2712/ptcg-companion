    'blog.meta.title': 'کافی نالج بیس | بیرسٹا فلو پروفیشنل گائیڈ خاصی کافی پینے کے لیے',
    'blog.meta.desc': 'یہاں، ہم آپ کے ساتھ کافی پینے کی سائنس، پانی کے درجہ حرارت کی طبیعیات، پیسنے کے سائز کی سنہری انشانکن، اور دنیا کے سرفہرست بارسٹاس سے پینے کے راز کا اشتراک کرتے ہیں۔ کلیدی متغیرات پر عبور حاصل کریں اور گھر پر ماسٹر کلاس کی خاصی کافی بنائیں۔',
    'blog.tag': 'کافی اکیڈمی',
    'blog.title': 'کافی علم کی بنیاد',
    'blog.subtitle': 'کافی پینا ایک نازک فن ہے جو فزکس اور کیمسٹری کو یکجا کرتا ہے۔ یہاں، ہم آپ کے لیے پیسنے کی ڈگری، پانی کے درجہ حرارت، اور تھری اسٹیج واٹر انجیکشن کے طریقہ کار کے پیچھے سائنسی اصولوں کی وضاحت کرتے ہیں، اور باریسٹا بننے کے سفر میں آپ کے ساتھ ہیں۔',
    'blog.readMore': 'مزید پڑھیں',
    'blog.breadcrumb': 'علم کی بنیاد',
    'blog.author': 'مصنف:',
    'blog.cta.title': 'یہ مضمون پسند ہے؟',
    'blog.cta.desc': 'بیرسٹا فلو کے پروفیشنل ٹائمر کا استعمال کریں تاکہ پکنے والی سائنس کو اپنی زبان پر حتمی ذائقہ میں تبدیل کیا جا سکے!',
    'blog.cta.btn': 'بریو ٹائمر فوری طور پر شروع کریں۔',
    'blog.post.meta.suffix': '| بارسٹا فلو کافی سائنس',

    'tools.bean.jsonld.name': 'کافی بین تازگی کیلکولیٹر',
    'tools.bean.jsonld.desc': 'پروفیشنل کافی بین ایگزاسٹ اور بین مینٹیننس پیریڈ کمپیوٹر۔ بھوننے کی ڈگری کی بنیاد پر بہترین ذائقہ کی مدت کی پیشین گوئی کریں، ضرورت سے زیادہ کاربن ڈائی آکسائیڈ کی وجہ سے ہونے والے اثرات سے بچیں، اور سنہری نکالنے کے وقت کو درست طریقے سے سمجھیں۔',
    'tools.bean.meta.title': 'کافی بین کی کاشت کی مدت کیلکولیٹر | بہترین ذائقہ کی مدت کی پیشن گوئی | بارسٹا فلو',
    'tools.bean.meta.desc': 'پروفیشنل کافی بین ایگزاسٹ اور بین مینٹیننس پیریڈ کمپیوٹر۔ کاربن ڈائی آکسائیڈ کے اخراج کی کیفیت اور سنہری ذائقہ کی مدت کا اندازہ لگانے کے لیے بھوننے کی تاریخ اور بھوننے کی ڈگری درج کریں، اور آپ کو سکھائیں کہ تازگی کی بنیاد پر شراب بنانے کی حکمت عملی کو کیسے ایڈجسٹ کیا جائے۔',
    'tools.bean.title': 'بین اگانے کا دورانیہ کمپیوٹر',
    'tools.bean.subtitle': 'کافی پھلیاں لوگوں کی طرح آرام کی ضرورت ہے! آپ کے لیے ایگزاسٹ سٹیٹ کا حساب لگانے اور سنہری ذائقے کی مدت کو درست طریقے سے حاصل کرنے کے لیے بھوننے کی تاریخ اور بھوننے کی ڈگری درج کریں۔',
    'tools.bean.setup.title': 'بیکنگ معلومات کی ترتیبات',
    'tools.bean.setup.date': 'روسٹ کی تاریخ',
    'tools.bean.setup.level': 'روسٹ لیول',
    'tools.bean.setup.level.light': 'ہلکا روسٹ - پھولوں اور پھلوں کی کھٹی مہک',
    'tools.bean.setup.level.medium': 'درمیانی روسٹ - میٹھا اور کھٹا توازن',
    'tools.bean.setup.level.dark': 'گہرا روسٹ - بھرپور کوکو',
    'tools.bean.status.title': 'تازگی کی حیثیت کا تجزیہ',
    'tools.bean.status.empty': 'براہ کرم بائیں طرف بیکنگ کی معلومات درج کریں۔',
    'tools.bean.status.empty.desc': 'تاریخ اور روسٹنگ ڈگری کو منتخب کرنے کے بعد، سسٹم خود بخود موجودہ ایگزاسٹ اسٹیٹس کا تجزیہ کرے گا۔',
    'tools.bean.status.days1': 'سینکا ہوا',
    'tools.bean.status.days2': 'آسمان',
    'tools.bean.h2_1': '"پھلیاں اٹھانا" کیوں ضروری ہے؟',
    'tools.bean.p1': 'کافی پھلیاں بھوننے کے عمل کے دوران **کاربن ڈائی آکسائیڈ (CO₂)** کی بڑی مقدار پیدا کرتی ہیں۔ تازہ بھنی ہوئی پھلیاں (جسے عام طور پر "تازہ کافی بینز" کہا جاتا ہے) کے خلیے ان گیسوں سے بھرے ہوتے ہیں۔ اگر آپ فوری طور پر پیس کر پانی ڈالتے ہیں، تو کاربن ڈائی آکسائیڈ کی ایک بڑی مقدار فوری طور پر خارج ہو جائے گی، جس سے بلبلوں کی ایک موٹی تہہ بن جائے گی۔ یہ نہ صرف پانی کو دور دھکیل دے گا، بلکہ ایک "چینلنگ اثر (چینلنگ)" کا سبب بنے گا، جس سے آپ کی کافی کا ذائقہ پانی دار ہو جائے گا، تیز کھٹا ذائقہ اور مٹھاس کی کمی کے ساتھ۔',
    'tools.bean.p2': 'نام نہاد "ڈیگاسنگ/ریسٹنگ" کا دورانیہ کافی بینز کو ایک طرفہ ایگزاسٹ والو کے ساتھ پیکج میں رکھنے کا عمل ہے تاکہ اضافی گیس کو قدرتی طور پر اور آہستہ سے خارج کیا جا سکے۔',
    'tools.bean.h2_2': 'بھوننے کی ڈگری ڈیگاسنگ کے وقت کو کیسے متاثر کرتی ہے؟',
    'tools.bean.p3': 'بھوننے کی مختلف سطحیں کافی بینز کے خلیوں کی ساخت کو مکمل طور پر تبدیل کر دیں گی، جس سے اخراج کی رفتار متاثر ہو گی۔',
    'tools.bean.li1': '**گہرا روسٹ**: لمبے عرصے تک بھوننے سے سیل کی دیواریں بہت نازک اور غیر محفوظ ہوجاتی ہیں اور سطح پر اکثر تیل رہتا ہے۔ گیس بہت آسانی سے نکل جاتی ہے۔ گہری بھنی ہوئی پھلیاں عام طور پر ڈیگاس میں صرف **3 سے 5 دن** لیتی ہیں اور ان کی مجموعی عمر کم ہوتی ہے۔',
    'tools.bean.li2': '**میڈیم روسٹ**: معتدل ڈھانچہ، عام طور پر میٹھا اور کھٹا توازن حاصل کرنے میں **7 سے 14 دن** لگتا ہے۔',
    'tools.bean.li3': '**ہلکا روسٹ**: بھوننے کا وقت کم ہے، پھلیاں سخت ہیں، اور سیل کی ساخت برقرار ہے۔ گیس اندر سے مضبوطی سے بند ہے اور انتہائی آہستہ سے ختم ہوتی ہے۔ ہلکی بھنی ہوئی پھلیاں اپنی بہترین پھولوں اور پھلوں کی خوشبو اور مٹھاس کو ظاہر کرنے کے لیے عام طور پر کم از کم **14 سے 21 دن** درکار ہوتی ہیں اور ان کی عمر بہت لمبی ہوتی ہے۔ بعض اوقات ذائقہ ایک ماہ تک ذخیرہ کرنے کے بعد بھی اپنے عروج پر ہوتا ہے۔',
    'tools.bean.h2_3': 'Coffee Bean کے تحفظ کے بارے میں 3 اکثر پوچھے گئے سوالات',
    'tools.bean.h3_1': 'کیا کافی پھلیاں کی سطح پر تیل خراب ہے؟',
    'tools.bean.p4': 'غیر یقینی تیل کا رساؤ (تیل کا رساؤ) گہری بھنی ہوئی کافی کی پھلیوں کا ایک عام جسمانی رجحان ہے، کیونکہ زیادہ درجہ حرارت بھوننے سے خلیے کی دیواریں پھٹ جاتی ہیں اور اندرونی لپڈز سطح پر فرار ہو جاتے ہیں۔ تاہم، اگر "ہلکی بھنی ہوئی یا درمیانی بھنی ہوئی" پھلیاں اچانک بڑی مقدار میں تیل پیدا کرتی ہیں، تو اس کا عام طور پر مطلب یہ ہوتا ہے کہ ذخیرہ کرنے کے ماحول کا درجہ حرارت بہت زیادہ ہے، یا پھلیاں بہت لمبے عرصے سے ذخیرہ کی گئی ہیں، اور پھلیاں بوڑھا ہونا شروع ہو گئی ہیں۔',
    'tools.bean.h3_2': 'اسے محفوظ رکھنے کا بہترین طریقہ کیا ہے؟',
    'tools.bean.p5': 'کافی کی پھلیاں محفوظ کرنے کے تین دشمن ہیں: آکسیجن، روشنی اور نمی۔ کافی کی پھلیاں ذخیرہ کرنے کا بہترین طریقہ یہ ہے کہ انہیں ایک مہر بند بیگ میں یک طرفہ ایگزاسٹ والو یا مبہم ویکیوم جار کے ساتھ ٹھنڈی، خشک الماری میں براہ راست سورج کی روشنی کے بغیر رکھیں۔ ریفریجریٹر میں کثرت سے استعمال ہونے والی کافی کی پھلیاں کبھی بھی فریج میں نہ رکھیں، کیونکہ ریفریجریٹر کھولنے اور بند کرتے وقت درجہ حرارت کے فرق سے پیدا ہونے والی نمی کافی کی پھلیاں جلد گیلی ہونے کا سبب بنتی ہے اور ریفریجریٹر میں موجود بدبو کو جذب کرتی ہے۔',
    'tools.bean.h3_3': 'کیا میں ریفریجریٹر میں کافی کی پھلیاں منجمد کر سکتا ہوں؟',
    'tools.bean.p6': 'ہاں، لیکن سخت شرائط ہیں۔ اگر آپ کافی بینز کی ایک بڑی مقدار خریدتے ہیں جو آپ ایک مہینے میں ختم نہیں کر سکتے ہیں، تو آپ انہیں چھوٹے سنگل بریو حصوں (جیسے سینٹری فیوج ٹیوب یا ویکیوم بیگ) میں "حصہ" کر سکتے ہیں اور انہیں فریزر میں گہرائی میں رکھ سکتے ہیں۔ جب آپ پکنا چاہیں تو صرف مطلوبہ مقدار نکال لیں "برف کو ہٹانے کی ضرورت نہیں" اور اسے فوراً پیس لیں۔ محتاط رہیں کہ پھلیاں کے پورے تھیلے کو بار بار فریزر کے اندر اور باہر نہ رکھیں، کیونکہ گاڑھی نمی کافی کے پورے بیگ کا ذائقہ مکمل طور پر ختم کر دے گی۔',
    'tools.bean.script.fresh.title': 'بہت تازہ',
    'tools.bean.script.fresh.desc': 'کافی کی پھلیاں ابھی بھنی ہوئی ہیں اور ان کے خلیوں میں کاربن ڈائی آکسائیڈ گیس بہت زیادہ ہوتی ہے۔ اس وقت، راستہ بہت پرتشدد ہے اور ذائقہ ابھی تک مستحکم نہیں ہوا ہے۔',
    'tools.bean.script.fresh.advice': '⚠️ **جبری شراب بنانے کی حکمت عملی**: اگر آپ کو ابھی پینا ہے، تو یقینی بنائیں کہ "بلوم ٹائم" کو 45 سے 60 سیکنڈ تک بڑھا دیں تاکہ گیس کو نکلنے کے لیے کافی وقت ملے اور چینلنگ اثرات کی وجہ سے ناکافی نکالنے سے بچ سکے۔',
    'tools.bean.script.peak.title': 'چوٹی ذائقہ ونڈو',
    'tools.bean.script.peak.desc': 'اخراج سست ہو گیا ہے، اور کافی کا میٹھا اور کھٹا توازن اور خوشبودار مادہ کی نشوونما اپنے بہترین عروج پر پہنچ گئی ہے۔ کافی بینز کے اس بیگ کے لیے اب سب سے مزیدار لمحہ ہے۔',
    'tools.bean.script.peak.advice': '✨ **بہترین شراب بنانے کی حکمت عملی**: شراب بنانے کے لیے صرف معیاری پیرامیٹرز استعمال کریں۔ پانی کا درجہ حرارت اور پیسنے کی ڈگری آپ کی باقاعدہ عادات کے مطابق ایڈجسٹ کی جا سکتی ہے۔ لطف اٹھائیں!',
    'tools.bean.script.mature.title': 'پختہ مستحکم مرحلہ (پختہ)',
    'tools.bean.script.mature.desc': 'کافی کی پھلیاں مکمل طور پر ختم ہو چکی ہیں، اور جب کہ جاندار مہک تھوڑی کم ہو گئی ہے، مٹھاس بہت مرتکز اور مکمل جسم بن گئی ہے۔',
    'tools.bean.script.mature.advice': '☕ **مستحکم شراب بنانے کی حکمت عملی**: کم اخراج والیوم کی وجہ سے، پاؤڈر بیڈ کے ذریعے پانی کے بہاؤ کی مزاحمت کم ہو جائے گی۔ مناسب نکالنے کی شرح کو برقرار رکھنے کے لیے "1 سے 2 قدم تک پیسنے کو باریک کریں" یا پانی کے درجہ حرارت کو 1°C تک بڑھانے کی سفارش کی جاتی ہے۔',
    'tools.bean.script.stale.title': 'دھندلاہٹ / باسی',
    'tools.bean.script.stale.desc': 'خوشبودار مادوں کی ایک بڑی مقدار میں اتار چڑھاؤ آ گیا ہے، سطح کا تیل آکسیڈائز ہونا شروع ہو سکتا ہے، اور ذائقہ نیرس ہو جاتا ہے یا اس میں ہلکی لکڑی یا تیل کی بو بھی آتی ہے۔',
    'tools.bean.script.stale.advice': '🆘 **ریسکیو بریونگ اسٹریٹجی**: باقی خوشبوؤں کو نچوڑنے کے لیے، پانی کے درجہ حرارت کو نمایاں طور پر اوپر کریں (جیسے 94-95°C) اور باریک پیس کر استعمال کریں۔ یا، ان پھلیوں کو "کولڈ بریو" بنانے کے لیے استعمال کریں۔ ٹھنڈا مرکب پرانی پھلیوں کی خامیوں کو مؤثر طریقے سے چھپا سکتا ہے۔',

    'tools.frenchpress.meta.title': 'فرانسیسی پریس کافی کیلکولیٹر اور ٹائمر | فرانسیسی پریس کافی کیلکولیٹر اور ٹائمر اسسٹنٹ',
    'tools.frenchpress.meta.desc': 'فرانسیسی پریس کافی کیلکولیٹر اور ٹائمر۔ آپ کو سکھائیں کہ 1:12 گولڈن پاؤڈر کو پانی کے تناسب سے کیسے استعمال کیا جائے اور موٹے پیسنے کا طریقہ آسانی سے مدھر، تیل والی کلاسک فرانسیسی پریس کافی بنانے کے لیے۔',
    'tools.frenchpress.jsonld.desc': 'درست فرانسیسی پریس کافی گراؤنڈز اور پانی کا تناسب کمپیوٹر اور ٹائمر۔ کامل بھیگنے اور نکالنے کے لیے 1:12 کے امیری کے تناسب کو حاصل کریں۔',
    'tools.frenchpress.title': 'فرانسیسی پریس کمپیوٹر',
    'tools.frenchpress.subtitle': 'ابتدائیوں کے لیے مکمل وسرجن پکنے کا بہترین طریقہ! یہ آپ کے لیے 1:12 بھرپور پانی سے پاؤڈر کے تناسب اور فرانسیسی پریس کے لیے موٹے پیسنے کی ترتیبات کے ساتھ پہلے سے لوڈ کیا گیا ہے، تاکہ آپ فوری طور پر اپنا مدھر نکالنا شروع کر سکیں۔',
    'tools.frenchpress.h2_1': 'اس فرنچ پریس کمپیوٹر کو کیسے استعمال کیا جائے؟',
    'tools.frenchpress.p1': 'فرانسیسی پریس ایک طویل عرصے سے قائم اور انتہائی مقبول پکنے کا آلہ ہے۔ V60 کے ڈرپ فلٹر کے طریقے کے برعکس، فرانسیسی پریس "مکمل وسرجن" نکالنے کا استعمال کرتا ہے۔ کافی پاؤڈر کافی دیر تک گرم پانی میں مکمل طور پر بھگو کر رکھا جاتا ہے، جس سے یہ کافی کا تیل اور جسم کو زیادہ سے زیادہ نکال سکتا ہے۔ یہ <strong> فرانسیسی پریس کیلکولیٹر </strong> پاؤڈر کو پانی کے تناسب اور بھیگنے کے وقت کو درست طریقے سے کنٹرول کرنے میں آپ کی مدد کرے گا۔',
    'tools.frenchpress.p2': 'ہم نے آپ کے لیے <strong>1:12</strong> کا گلابی سے پانی کا تناسب پہلے سے لوڈ کیا ہے، جو فرانسیسی پریس کے برتنوں کے لیے سب سے زیادہ کلاسک امیر تناسب ہے۔ چونکہ فرانسیسی پریس پیپر فلٹر کا استعمال نہیں کرتا ہے، کافی کریم کو برقرار رکھا جاتا ہے، اور 1:12 سے 1:15 کے تناسب کا استعمال ایک بہت ہی بھرپور ماؤتھ فیل بناتا ہے۔ بس اوپر اپنے کافی بین کا وزن درج کریں اور کمپیوٹر خود بخود پانی کی کل مقدار کا حساب لگائے گا۔',
    'tools.frenchpress.h2_2': 'فرانسیسی پریس کے لیے 3 پرو ٹپس',
    'tools.frenchpress.li1': '<strong> موٹے پیسنے کا استعمال کریں </strong>: فرانسیسی پریس کے دھاتی فلٹر میں بڑے سوراخ ہوتے ہیں۔ اگر پیسنا بہت باریک ہے تو کافی پاؤڈر دھاتی جالی سے گزر کر آپ کے کپ میں چلا جائے گا، جس سے ذائقہ ابر آلود ہو جائے گا۔ ایک موٹا پیسنا (موٹے سمندری نمک کا سائز) ایک کامیاب فرانسیسی پریس کی کلید ہے۔',
    'tools.frenchpress.li2': '<strong> کرسٹ کو توڑنا </strong>: پانی بھرنے کے بعد 4 منٹ انتظار کریں، اور کافی پاؤڈر سطح پر ایک کرسٹ (Crust) بن جائے گا۔ اسے توڑنے کے لیے اسے ہلکے سے ہلانے کے لیے چمچ کا استعمال کریں، جس سے زیادہ تر کافی پاؤڈر نیچے تک ڈوب جائے، اور پھر سطح پر باقی سفید جھاگ اور باریک پاؤڈر کو ہٹانے کے لیے چمچ کا استعمال کریں۔ اس قدم کو "جیمز ہوفمین تکنیک" کہا جاتا ہے اور یہ آپ کی فرانسیسی پریس کافی کو ناقابل یقین حد تک صاف کر دے گا۔',
    'tools.frenchpress.li3': '<strong> اسے ہر طرح سے نہ دبائیں </strong>: بہت سے لوگ کافی پاؤڈر کو نچوڑنے کے لیے پوری طرح لیور کو دبانے کے عادی ہیں۔ اس سے کڑوے مادے اور باریک پاؤڈر نکل جائے گا۔ آپ کو دباؤ والی چھڑی کو صرف اس پوزیشن پر نیچے دبانے کی ضرورت ہے جہاں یہ فلٹرنگ کے لیے کافی پاؤڈر کی سطح کو چھوتا ہے۔',
    'tools.frenchpress.h2_3': 'عام غلطیاں',
    'tools.frenchpress.h3_1': '1. بھیگنے کا وقت بہت کم یا بہت لمبا ہے۔',
    'tools.frenchpress.p3': 'بہت سے لوگ صرف 2 منٹ کے لئے بھگوتے ہیں اور نیچے دبانے کے لئے جلدی کرتے ہیں، جو ناکافی نکالنے اور کھٹا اور پانی دار ذائقہ کا باعث بنے گا۔ معیاری فرانسیسی پریس میں بھیگنے کا وقت <strong> 4 منٹ </strong> ہے۔ اگر آپ نے اوپر کی شیل توڑنے والی تکنیک کا استعمال کیا ہے، تو آپ اسے 5-8 منٹ تک بیٹھنے بھی دے سکتے ہیں تاکہ باریک پاؤڈر مکمل طور پر جم جائے۔',
    'tools.frenchpress.h3_2': '2. ہر آخری قطرہ کپ میں ڈالیں۔',
    'tools.frenchpress.p4': 'یہاں تک کہ اگر دھات کا فلٹر زیادہ تر کافی کے میدانوں کو روک سکتا ہے، تب بھی برتن کے نچلے حصے میں بہت زیادہ کیچڑ موجود رہے گا۔ کافی ڈالتے وقت، براہ کرم اسے آہستہ سے ڈالیں، اور <strong>کافی کا آخری گھونٹ نہ ڈالیں</strong>، اسے برتن کے نیچے چھوڑ دیں، اور آپ کے کپ میں موجود کافی زیادہ صاف ہو جائے گی۔',
    'tools.frenchpress.h3_3': '3. کیتلی کے جسم کو پہلے سے گرم کرنا بھول گئے۔',
    'tools.frenchpress.p5': 'فرانسیسی پریس عام طور پر شیشے سے بنے ہوتے ہیں، اور شیشے میں گرمی جذب کرنے کی مضبوط صلاحیت ہوتی ہے۔ اگر آپ 90°C گرم پانی کو براہ راست شیشے کے ٹھنڈے جگ میں ڈالتے ہیں، تو پانی کا درجہ حرارت فوری طور پر 80°C سے نیچے گر سکتا ہے، جس کے نتیجے میں پانی نکالنا کم ہو جاتا ہے۔ گراؤنڈ کافی ڈالنے سے پہلے کیتلی کو گرم پانی سے گرم کرنا یقینی بنائیں۔',
    'tools.frenchpress.p6': 'کیا آپ تیار ہیں؟ 4 منٹ کا الٹی گنتی سیٹ کرنے کے لیے اوپر کا ٹائمر استعمال کریں اور فرنچ پریس کی طرف سے لائے گئے مدھر چکنائی اور اصل ذائقے سے لطف اندوز ہوں!',

    'grind.meta.title': 'یونیورسل گرائنڈ کنورٹر | گرائنڈر اسکیل موازنہ چارٹ | بارسٹا فلو',
    'grind.meta.desc': 'گرائنڈرز کے بڑے برانڈز کے پیسنے والے پیسنے کو درست طریقے سے تبدیل کریں (کمانڈنٹ C40، ٹائممور C2/C3، فیلو اوڈ، باراتزا انکور، وغیرہ)۔ اطالوی، دستی اور فرانسیسی پریس برتنوں کے لیے بلٹ ان کامل پیرامیٹر کا موازنہ۔',
    'grind.title': 'یونیورسل گرائنڈ کنورٹر',
    'grind.subtitle': 'مجھے ایک نیا گرائنڈر مل گیا ہے، لیکن مجھے نہیں معلوم کہ پچھلی ترکیب کے لیے کون سا پیمانہ استعمال کرنا ہے؟ اپنے الگورتھم کے ذریعے، ہم خود بخود آپ کی مدد کر سکتے ہیں کہ اصل پیسنے والے پیمانے کو آپ کے نئے گرائنڈر پر نقشہ بنا سکیں۔',
    'grind.source.title': 'آپ کی موجودہ چکی',
    'grind.selectBrand': 'برانڈ اور ماڈل منتخب کریں۔',
    'grind.currentScale': 'موجودہ پیمانہ',
    'grind.target.title': 'تبادلوں کا ہدف چکی',
    'grind.selectTarget': 'ہدف برانڈ اور ماڈل منتخب کریں۔',
    'grind.result': 'تبادلوں کا نتیجہ',
    'grind.gauge.title': 'بریونگ وقفہ ڈراپ پوائنٹ',
    'grind.gauge.select': 'براہ کرم پیمانہ منتخب کریں۔',
    'grind.apply': 'اس پیمانے کو میرے ٹائمرز پر لاگو کریں۔',

    'terms.meta.title': 'سروس کی شرائط | بارسٹا فلو',
    'terms.meta.desc': 'Barista Flow سروس کی شرائط اور دستبرداری۔',
    'terms.title': 'سروس کی شرائط',
    'terms.date': 'آخری بار اپ ڈیٹ کیا گیا: 28 مئی 2026',
    'terms.p1': 'Barista Flow میں خوش آمدید۔ براہ کرم اس ویب سائٹ کو استعمال کرنے سے پہلے درج ذیل شرائط کو غور سے پڑھیں۔ اس ویب سائٹ کا استعمال کرتے ہوئے آپ ان شرائط کے پابند ہونے سے اتفاق کرتے ہیں۔',
    'terms.s1.title': '1. سروس کی تفصیل',
    'terms.s1.p1': 'Barista Flow مفت آن لائن کافی پکنے کے ٹائمر، نسخہ کیلکولیشن ٹولز اور کافی کا متعلقہ علم فراہم کرتا ہے۔ یہ ویب سائٹ ایک جامد کلائنٹ ایپلی کیشن ہے۔',
    'terms.s2.title': '2. صارف کی ذمہ داریاں',
    'terms.s2.p1': 'آپ اس بات سے اتفاق کرتے ہیں کہ اس ویب سائٹ کو کسی بھی غیر قانونی سرگرمی کو انجام دینے یا ویب سائٹ کے معمول کے کام میں خلل ڈالنے کے لیے استعمال نہیں کریں گے۔ اس ویب سائٹ کے آپ کے استعمال سے پیدا ہونے والے کوئی بھی نتائج (جیسے شراب بنانے کی ترکیبیں) صرف معلوماتی مقاصد کے لیے ہیں۔',
    'terms.s3.title': '3. دستبرداری',
    'terms.s3.p1': 'یہ ویب سائٹ کسی بھی قسم کی وارنٹی کے بغیر "جیسے ہے" فراہم کی گئی ہے۔ ہم اس بات کی ضمانت نہیں دیتے کہ ویب سائٹ ہمیشہ غلطیوں سے پاک یا بلاتعطل ہوگی۔ گرائنڈر کے مختلف ماڈلز، کٹر ہیڈ پہننے اور کافی بین کی حالتوں کی وجہ سے، اس ویب سائٹ پر فراہم کردہ کوئی بھی پیسنے والے پیرامیٹرز اور پیسنے کی ڈگری کے تبادلوں کے نتائج صرف <strong>ریفرنس بینچ مارکس</strong> ہیں، اور ہم اس کافی کے ذائقے کے ذمہ دار نہیں ہیں جو آپ حقیقت میں پیتے ہیں۔',
    'terms.s4.title': '4. دانشورانہ املاک کے حقوق',
    'terms.s4.p1': 'اس ویب سائٹ کا ڈیزائن، کوڈ، لوگو اور متن کا مواد کاپی رائٹ قانون کے ذریعے محفوظ ہے۔ کسی غیر مجاز کاپی یا تجارتی استعمال کی اجازت نہیں ہے۔',
    'terms.s5.title': '5. تیسرے فریق کے اشتہارات اور لنکس',
    'terms.s5.p1': 'اس ویب سائٹ میں گوگل ایڈسینس کے اشتہارات اور فریق ثالث کی ویب سائٹس کے لنکس ہو سکتے ہیں۔ ہم ان اشتہارات اور ویب سائٹس کے مواد کے ذمہ دار نہیں ہیں۔ مزید معلومات کے لیے براہ کرم ہماری پرائیویسی پالیسی دیکھیں۔',
    'terms.s6.title': '6. شرائط میں ترمیم',
    'terms.s6.p1': 'ہم کسی بھی وقت ان شرائط میں ترمیم کرنے کا حق محفوظ رکھتے ہیں۔ نظرثانی شدہ شرائط اس صفحہ پر پوسٹ ہونے کے فوراً بعد نافذ العمل ہوں گی۔',

    'privacy.meta.title': 'رازداری کی پالیسی رازداری کی پالیسی | بارسٹا فلو',
    'privacy.meta.desc': 'Barista Flow کی رازداری کی پالیسی اور کوکی اسٹیٹمنٹ، GDPR، CCPA اور Google AdSense کے مطابق۔',
    'privacy.title': 'رازداری کی پالیسی',
    'privacy.date': 'آخری بار اپ ڈیٹ کیا گیا: 28 مئی 2026',
    'privacy.p1': 'Barista Flow ("سائٹ") میں خوش آمدید۔ ہم آپ کی رازداری کو بہت سنجیدگی سے لیتے ہیں۔ اس رازداری کی پالیسی کا مقصد یہ بتانا ہے کہ ہم آپ کے ذاتی ڈیٹا کو کس طرح اکٹھا کرتے ہیں، استعمال کرتے ہیں اور اس کی حفاظت کرتے ہیں، اور یہ ویب سائٹ کوکیز اور تیسرے فریق کی اشتہاری خدمات (خاص طور پر گوگل ایڈسینس) کو کس طرح استعمال کرتی ہے۔',
    'privacy.s1.title': '1. ڈیٹا اکٹھا کرنا اور استعمال کرنا',
    'privacy.s1.p1': 'ایک جامد کلائنٹ ٹول کے طور پر، یہ ویب سائٹ <strong> آپ کو فعال طور پر اکاؤنٹ رجسٹر کرنے کے لیے نہیں کہے گی، اور نہ ہی یہ آپ کی کافی پینے کی کوئی ترکیب ہمارے سرور کو بھیجے گی </strong>۔ آپ کے درج کردہ تمام پیرامیٹر اور ہسٹری ریکارڈز صرف آپ کے مقامی براؤزر کے <code> لوکل اسٹوریج </code> میں محفوظ ہیں۔',
    'privacy.s2.title': '2. کوکیز اور تھرڈ پارٹی ٹریکنگ ٹیکنالوجیز',
    'privacy.s2.p1': 'بہترین براؤزنگ کا تجربہ فراہم کرنے اور ویب سائٹ کے آپریشنز کو برقرار رکھنے کے لیے، یہ ویب سائٹ کوکیز اور اسی طرح کی ٹریکنگ ٹیکنالوجیز کا استعمال کرتی ہے۔ جب آپ اس ویب سائٹ کو براؤز کرتے ہیں، تو ہم یا ہمارے تیسرے فریق پارٹنرز آپ کے آلے پر کوکیز اسٹور کر سکتے ہیں۔',
    'privacy.s2.sub': 'گوگل ایڈسینس اور ایڈورٹائزنگ کوکیز',
    'privacy.s2.p2': 'یہ ویب سائٹ تیسرے فریق کے اشتہارات پیش کرنے کے لیے گوگل ایڈسینس کا استعمال کرتی ہے۔ Google کی ناشر کی پالیسیوں کی تعمیل کرنے کے لیے، ہم یہاں اعلان کرتے ہیں:',
    'privacy.s2.l1': 'فریق ثالث فروش، بشمول گوگل، اشتہارات پیش کرنے کے لیے کوکیز کا استعمال کرتے ہیں۔ یہ اشتہارات اس اور دیگر ویب سائٹس پر آپ کے پچھلے دوروں پر مبنی ہیں۔',
    'privacy.s2.l2': 'گوگل کا <strong>اشتہاری کوکیز</strong> کا استعمال Google اور اس کے شراکت داروں کو آپ کے ہماری سائٹ اور/یا انٹرنیٹ پر دیگر سائٹس پر جانے کی بنیاد پر آپ کو انتہائی متعلقہ اشتہارات دکھانے کی اجازت دیتا ہے۔',
    'privacy.s2.l3': 'آپ کسی بھی وقت Google اشتہارات کی ترتیبات میں جا کر ذاتی نوعیت کے اشتہارات سے آپٹ آؤٹ کر سکتے ہیں۔',
    'privacy.s3.title': '3. GDPR اور CCPA صارف کے حقوق کا بیان',
    'privacy.s3.p1': 'ہم یورپی جنرل ڈیٹا پروٹیکشن رول (GDPR) اور کیلیفورنیا کنزیومر پرائیویسی ایکٹ (CCPA) کی تعمیل کرنے کے پابند ہیں:',
    'privacy.s3.l1': '<strong> رضامندی اور واپسی (GDPR) </strong> : ہمارے پاس ہماری ویب سائٹ کے نیچے کوکی رضامندی کا بینر ہے۔ اگر آپ رضامندی پر کلک نہیں کرتے ہیں، تو ہم غیر ضروری تھرڈ پارٹی ٹریکنگ کو محدود کر دیں گے۔ آپ اپنے براؤزر کی کوکیز کو صاف کر کے کسی بھی وقت اپنی رضامندی کی حیثیت کو دوبارہ ترتیب دے سکتے ہیں۔',
    'privacy.s3.l2': '<strong> ذاتی معلومات فروخت نہ کریں (CCPA) </strong>: یہ ویب سائٹ کبھی بھی آپ کی ذاتی طور پر قابل شناخت معلومات (PII) کو جمع یا فروخت نہیں کرے گی۔ تمام اشتہاری ڈیٹا کی ترسیل کو گوگل ایڈسینس کے ذریعے گمنام طریقے سے سنبھالا جاتا ہے۔',
    'privacy.s4.title': '4. بیرونی روابط',
    'privacy.s4.p1': 'اس ویب سائٹ پر مواد یا مضامین دیگر بیرونی ویب سائٹس کے لنکس پر مشتمل ہو سکتے ہیں۔ براہ کرم نوٹ کریں کہ ہم ان بیرونی سائٹس کے رازداری کے طریقوں یا مواد کے ذمہ دار نہیں ہیں۔ جب آپ ہماری ویب سائٹ چھوڑتے ہیں، تو ہم تجویز کرتے ہیں کہ آپ اس ویب سائٹ کا رازداری کا بیان پڑھیں۔',
    'privacy.s5.title': '5. پالیسی میں ترامیم',
    'privacy.s5.p1': 'ہم کسی بھی وقت اس رازداری کی پالیسی میں ترمیم کرنے کا حق محفوظ رکھتے ہیں۔ کسی بھی تبدیلی کو اس صفحہ پر پوسٹ کیا جائے گا اور سب سے اوپر "آخری اپ ڈیٹ" کی تاریخ کو اپ ڈیٹ کیا جائے گا۔ ہم آپ کو تازہ ترین معلومات کے لیے اس صفحہ کو باقاعدگی سے چیک کرنے کی ترغیب دیتے ہیں۔',
    'privacy.s6.title': '6. ہم سے رابطہ کریں۔',
    'privacy.s6.p1': 'اگر آپ کے پاس اس رازداری کی پالیسی یا ہمارے ڈیٹا ہینڈلنگ کے طریقوں کے بارے میں کوئی سوالات ہیں، تو براہ کرم ہم سے رابطہ کریں صفحہ کے ذریعے ہم سے رابطہ کریں۔',

    'faq.meta.title': 'اکثر پوچھے گئے سوالات FAQ | کافی پینے کی خرابی کا سراغ لگانا',
    'faq.meta.desc': 'کافی کڑوی کیوں ہے؟ گلابی سے پانی کے تناسب کا حساب کیسے لگائیں؟ یہاں پر کافی سے متعلق اکثر پوچھے گئے سوالات تلاش کریں اور جانیں کہ اپنی شراب بنانے کی تکنیک کو کیسے بہتر بنایا جائے۔',
    'faq.title': 'اکثر پوچھے گئے سوالات (FAQ)',
    'faq.subtitle': 'ہاتھ سے تیار کی گئی کافی اور ٹائمر کے بارے میں اکثر پوچھے جانے والے سوالات',
    'faq.q1': 'میری ہاتھ سے بنائی ہوئی کافی کا ذائقہ کڑوا کیوں ہے؟',
    'faq.a1': 'کافی میں تلخی عام طور پر "زیادہ نکالنے" کی وجہ سے ہوتی ہے۔ یہ پانی کا درجہ حرارت بہت زیادہ ہونے، پیسنے کا پیمانہ بہت باریک ہونے کی وجہ سے ہو سکتا ہے جس کے نتیجے میں بہت زیادہ باریک پاؤڈر ہو، یا نکالنے کا وقت بہت لمبا ہو۔ یہ سفارش کی جاتی ہے کہ آپ پیسنے کی ڈگری کو ایک یا دو نشانوں سے ایڈجسٹ کرنے کی کوشش کریں، یا بعد کے مرحلے میں جلے ہوئے اور کڑوے مادے کی تحلیل سے بچنے کے لیے ہر مرحلے کے پانی کے انجیکشن کے وقت کو درست طریقے سے کنٹرول کرنے کے لیے ہمارے پروفیشنل بریونگ ٹائمر کا استعمال کریں۔',
    'faq.q2': 'کافی بینز کو تازہ رکھنے کے لیے انہیں کیسے ذخیرہ کیا جانا چاہیے؟',
    'faq.a2': 'کافی کی پھلیاں کے سب سے بڑے دشمن آکسیجن، روشنی، نمی اور زیادہ درجہ حرارت ہیں۔ کافی کی پھلیاں ذخیرہ کرنے کا مثالی طریقہ یہ ہے کہ انہیں ایک مبہم مہر بند جار یا ایک طرفہ ایگزاسٹ والو کے ساتھ ایئر ٹائٹ بیگ میں رکھیں اور اسے ٹھنڈی، خشک الماری میں رکھیں۔ ریفریجریٹر میں روزانہ استعمال کے لیے کافی کی پھلیاں نہ رکھیں تاکہ درجہ حرارت کے فرق کی وجہ سے ہونے والی سنسنیشن کو روکا جا سکے اور کافی کی پھلیاں خراب ہونے کو تیز کریں۔',
    'faq.q3': 'ہلکی روسٹ اور ڈارک روسٹ کافی کے درمیان پکنے میں کیا فرق ہے؟',
    'faq.a3': 'ہلکی بھنی ہوئی کافی کی پھلیاں سخت ساخت اور زیادہ پھولدار اور پھل دار ذائقہ رکھتی ہیں، جس کے لیے پانی کا زیادہ درجہ حرارت (تقریباً 91°C-94°C) اور مکمل نکالنے کے لیے باریک پیسنے کی ضرورت ہوتی ہے۔ گہرے بھنی ہوئی کافی کی پھلیاں ڈھیلی ڈھانچہ، گہری کیریملائزیشن اور کڑواہٹ کو آسانی سے خارج کرتی ہیں، اس لیے پانی کا کم درجہ حرارت (تقریباً 85°C-88°C) استعمال کرنے اور موٹے پیسنے کی سفارش کی جاتی ہے۔ اگر آپ کو اس بات کا یقین نہیں ہے کہ کس طرح ایڈجسٹ کرنا ہے، تو مختلف روسٹ لیولز کے مطابق پیرامیٹرز بنانے کے لیے ہمارے brew recipe calculator کو آزمائیں۔',
    'faq.q4': '"چینلنگ" کیا ہے اور اس سے کیسے بچنا ہے؟',
    'faq.a4': 'چینل ایفیکٹ کا مطلب یہ ہے کہ کم سے کم مزاحمت کے ساتھ شارٹ کٹ کے ذریعے پاؤڈر بیڈ میں پانی بہتا ہے، جس کی وجہ سے کچھ پاؤڈر زیادہ نکالا جاتا ہے اور کچھ کو نہیں نکالا جا سکتا، جس کے نتیجے میں کافی ایک ہی وقت میں کھٹی اور کڑوی ہوتی ہے۔ چینلنگ سے بچنے کے لیے، اس بات کو یقینی بنائیں کہ پاؤڈر یکساں طور پر تقسیم ہو، جرمانے کو کم کرنے کے لیے ایک بہتر معیار کی چکی کا استعمال کریں، اور پانی بھرتے وقت پانی کے بہاؤ کو مستحکم اور نرم رکھیں، بغیر پاؤڈر کے بستر کو بھرپور طریقے سے دھوئے۔',
    'faq.q5': 'بریو ریشو کو کیسے سمجھیں؟',
    'faq.a5': 'خاص ہاتھ سے تیار کی گئی کافی کے لیے زمین سے پانی کا معیاری تناسب عام طور پر 1:15 اور 1:17 کے درمیان ہوتا ہے (یعنی 1 گرام زمینی کافی 15 سے 17 گرام پانی کے مساوی ہے)۔ 1:15 ایک بھرپور اور مدھر ذائقہ ہے، جبکہ 1:17 تازگی اور چمکدار ہے۔ آپ اسے اپنے ذاتی ذوق کے مطابق ٹھیک کر سکتے ہیں۔ ہمارے کافی تناسب کے اسسٹنٹ کے ساتھ، آپ کے ہاتھ میں موجود کافی بینز کے گرام درج کریں اور سسٹم خود بخود آپ کے لیے پانی کی صحیح مقدار کا حساب لگائے گا۔',
    'faq.q6': 'کھلنے کے دوران کافی پاؤڈر کیوں نہیں پھیلتا؟',
    'faq.a6': 'کافی گراؤنڈ کا بستر بھاپ کے دوران پھیلتا ہے کیونکہ پھلیاں بھوننے کے دوران پیدا ہونے والی کاربن ڈائی آکسائیڈ کو خارج کرتی ہیں۔ اگر بالکل بھی توسیع نہیں ہے تو، سب سے عام وجہ یہ ہے کہ کافی کی پھلیاں بہت دیر تک رہ گئی ہیں اور ان کا اخراج ختم ہو گیا ہے (اب تازہ نہیں ہے)؛ اس کے علاوہ، اگر یہ انتہائی ہلکی بھنی ہوئی کافی ہے، تو راستہ کا ردعمل نسبتاً کمزور ہوگا۔ بس اس بات کو یقینی بنائیں کہ پھلیاں بھوننے کے ایک ماہ کے اندر کھائی جائیں اور وہ عام طور پر اچھا ذائقہ برقرار رکھیں گی۔',


