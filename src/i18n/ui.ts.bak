    'tools.watertemp.jsonld.name': 'Water Temp Predictor',
    'tools.watertemp.jsonld.desc': 'Accurately predict water cooling time.',
    'tools.watertemp.meta.title': 'Water Temp Predictor | Barista Flow',
    'tools.watertemp.meta.desc': 'Use Newton\'s Law of Cooling to predict your kettle\'s temperature drop.',
    'tools.watertemp.h2': 'Why Predict Water Temperature?',
    'tools.watertemp.p1': 'Water temperature is critical for extraction. Boiling water can cause over-extraction and bitterness.',
    'tools.watertemp.p2': 'Using a thermometer every time disrupts workflow.',
    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'स्टेनलेस स्टील हैंड ब्रू केतली',
    'tools.watertemp.script.impossible': 'हासिल करने में असमर्थ',
    'tools.bean.faq.1.q': 'कॉफ़ी बीन्स की "डीगैसिंग" प्रक्रिया क्या है?',
    'tools.bean.faq.1.a': 'भूनने की प्रक्रिया के दौरान, कॉफी बीन्स बड़ी मात्रा में कार्बन डाइऑक्साइड का उत्पादन करते हैं जो कोशिका संरचना में बंद हो जाता है। ताजी भुनी हुई कॉफी बीन्स बहुत तेजी से गैस छोड़ती हैं। यदि तुरंत बनाया जाए, तो बड़ी संख्या में बुलबुले गर्म पानी और कॉफी पाउडर के बीच संपर्क को रोक देंगे, जिसके परिणामस्वरूप अपर्याप्त निष्कर्षण और कमजोर स्वाद होगा। तथाकथित "बीन रेजिंग" कॉफ़ी बीन्स को कुछ {t(\'tools.bean.status.days2\')} तक खड़े रहने देने की प्रक्रिया है ताकि अतिरिक्त कार्बन डाइऑक्साइड को स्वाभाविक रूप से जारी किया जा सके और कॉफ़ी के स्वाद का सर्वोत्तम संतुलन प्राप्त किया जा सके।',
    'tools.bean.faq.2.q': 'ताज़गी बनाए रखने के लिए कॉफ़ी बीन्स को ठीक से कैसे स्टोर करें?',
    'tools.bean.faq.2.a': 'कॉफ़ी बीन्स के संरक्षण के तीन दुश्मन हैं: ऑक्सीजन, प्रकाश और नमी। कॉफ़ी बीन्स को स्टोर करने का सबसे अच्छा तरीका यह है कि उन्हें एक सीलबंद बैग में एक तरफ़ा निकास वाल्व या एक अपारदर्शी वैक्यूम जार में सीधे धूप के बिना ठंडी, सूखी अलमारी में रखा जाए। बार-बार उपयोग की जाने वाली कॉफी बीन्स को कभी भी रेफ्रिजरेटर में न रखें, क्योंकि रेफ्रिजरेटर खोलने और बंद करने पर तापमान के अंतर से उत्पन्न नमी के कारण कॉफी बीन्स जल्दी से नम हो जाएंगी और गंध को अवशोषित कर लेंगी।',
    'tools.bean.faq.3.a': 'हाँ, लेकिन कड़ी शर्तें हैं। यदि आप बड़ी मात्रा में कॉफी बीन्स खरीदते हैं जिन्हें आप एक महीने के भीतर खत्म नहीं कर सकते हैं, तो आप उन्हें छोटे सिंगल-ब्रू भागों (जैसे टेस्ट ट्यूब या वैक्यूम बैग) में "हिस्सा" कर सकते हैं और उन्हें फ्रीजर में गहराई से रख सकते हैं। जब आप काढ़ा बनाना चाहते हैं, तो बस आवश्यक मात्रा "बर्फ हटाने की आवश्यकता नहीं" निकाल लें और इसे तुरंत पीस लें। सावधान रहें कि बीन्स के पूरे बैग को बार-बार फ्रीजर के अंदर और बाहर न रखें, क्योंकि इससे कॉफी का स्वाद पूरी तरह से नष्ट हो जाएगा।',
    'tools.bean.jsonld.name': 'कॉफ़ी बीन्स और ताज़गी कैलकुलेटर (बीन ताज़गी कैलकुलेटर)',
    'tools.bean.jsonld.desc': 'कॉफी बीन्स की भूनने की तारीख और भूनने की डिग्री के आधार पर, यह सटीक रूप से गणना कर सकता है कि क्या यह सुनहरे स्वाद की अवधि में है और पेशेवर ब्रूइंग पैरामीटर समायोजन सुझाव प्रदान करता है।',
    'tools.bean.meta.title': 'कॉफ़ी बीन की खेती और ताज़गी कैलकुलेटर | स्वर्णिम स्वाद अवधि की भविष्यवाणी | बरिस्ता प्रवाह',
    'tools.bean.meta.desc': 'क्या आपकी कॉफी बीन्स अच्छी तरह से बढ़ रही हैं? भूनने की तारीख दर्ज करें, और हमारा बुद्धिमान कंप्यूटर आपको बताएगा कि कॉफी बीन्स वर्तमान में समाप्ति अवधि, सुनहरे स्वाद की अवधि या गिरावट की अवधि में हैं, और आपको सर्वोत्तम ब्रूइंग सुझाव देगा।',
    'tools.bean.title': 'कॉफ़ी बीन्स और ताज़गी कैलकुलेटर',
    'tools.bean.subtitle': 'सर्वोत्तम निष्कर्षण समय में महारत हासिल करें। अपनी कॉफी बीन्स के वर्तमान स्वाद और गैस निकलने की स्थिति को समझने के लिए भूनने की तारीख और भूनने की डिग्री दर्ज करें।',
    'tools.bean.label.date': '{t(\'tools.bean.setup.date\')} रैपर पर',
    'tools.bean.label.level': 'भूनने का स्तर',
    'tools.bean.opt.light': 'हल्का भुनना - लंबी खेती अवधि',
    'tools.bean.opt.medium': 'मीडियम रोस्ट - मानक',
    'tools.bean.opt.dark': 'डार्क रोस्ट - जितनी जल्दी हो सके पी लें',
    'tools.bean.status.passed': 'बेकिंग का दिन बीत गया',
    'tools.bean.status.days': 'आकाश',
    'tools.bean.status.current': 'वर्तमान स्वाद स्थिति',
    'tools.bean.status.golden': 'सुनहरा स्वाद अवधि',
    'tools.bean.status.golden.desc': 'निकास का काम पूरा हो चुका है और स्वाद का विकास अपने चरम पर पहुंच गया है। कॉफ़ी बीन्स के इस बैग के लिए अब सबसे स्वादिष्ट क्षण है।',
    'tools.bean.graph.title': 'कॉफ़ी बीन जीवन चक्र वक्र',
    'tools.bean.graph.phase1': 'निकास अवधि',
    'tools.bean.graph.phase3': 'परिपक्व स्थिर अवधि',
    'tools.bean.graph.phase4': 'स्वाद में गिरावट की अवधि',
    'tools.bean.advice.title': 'शराब बनाने की रणनीति के सुझाव',
    'tools.bean.empty.prompt': 'कृपया गणना के लिए पैकेज पर भूनने की तारीख का चयन करें',
    'tools.bean.faq.title': 'कॉफ़ी बीन्स के बारे में अक्सर पूछे जाने वाले प्रश्न',
    'tools.bean.faq.3.q': 'क्या मैं कॉफ़ी बीन्स को रेफ्रिजरेटर में जमा सकता हूँ?',
    'tools.bean.faq.1.a_text': 'भूनने की प्रक्रिया के दौरान, कॉफी बीन्स बड़ी मात्रा में कार्बन डाइऑक्साइड का उत्पादन करते हैं जो कोशिका संरचना में बंद हो जाता है। ताज़ी भुनी हुई कॉफ़ी बीन्स बहुत ही तीक्ष्ण होती हैं। यदि तुरंत पीसा जाए, तो बड़ी संख्या में बुलबुले गर्म पानी और कॉफी पाउडर के बीच संपर्क को रोक देंगे, जिसके परिणामस्वरूप अपर्याप्त निष्कर्षण और कमजोर स्वाद (यानी, सामान्य जल चैनल प्रभाव) होगा। तथाकथित "बीन रेजिंग" एक शारीरिक प्रक्रिया है जिसमें कॉफी बीन्स को कई दिनों तक आराम करने के लिए छोड़ दिया जाता है ताकि अतिरिक्त कार्बन डाइऑक्साइड स्वाभाविक रूप से निकल जाए और कॉफी के स्वाद का सर्वोत्तम संतुलन प्राप्त हो सके।',

    'tools.default.bean.aeropress': 'ग्वाटेमाला हुइहुइटनांगो',
    'tools.default.bean.coldbrew': 'डार्क रोस्टेड चॉकलेट मिश्रित बीन्स',
    'tools.default.bean.frenchpress': 'कोलंबिया ने धोया',
    'tools.default.bean.v60': 'इथियोपिया यिरगाशेफ़े',
    'tools.default.grind.aeropress': 'मध्यम से महीन पीसना (जैसे महीन रेत)',
    'tools.default.grind.coldbrew': 'बहुत मोटा पीस',
    'tools.default.grind.frenchpress': 'दरदरा पिसा हुआ (कोषेर नमक की तरह)',
    'tools.default.grind.v60': 'मध्यम से बारीक पीसने के लिए (केवल मैन्युअल पीसने के लिए)',
    'tools.v60.p3': 'हारियो V60 दुनिया में सबसे लोकप्रिय हाथ से बनाई गई कॉफी उपकरणों में से एक है। इसका अनोखा 60-डिग्री पतला डिज़ाइन, बड़े व्यास वाला निचला छेद और सर्पिल जल गाइड बरिस्ता को जल प्रवाह नियंत्रण में उच्च स्तर की स्वतंत्रता देता है। लेकिन इस वजह से, V60 पानी के इंजेक्शन की लय और स्थिरता पर बहुत भारी है। यह <strong>{t(\'tools.v60.title\')} (V60 कैलकुलेटर)</strong> और टाइमर इस समस्या को हल करने के लिए डिज़ाइन किए गए हैं।',
    'grind.meta.desc': 'सबसे उत्तम ब्रूइंग मापदंडों को खोजने के लिए प्रमुख ब्रांडों के ग्राइंडर (कोमांडेंट सी40, टाइममोर, फेलो ओड, बाराट्ज़ा एनकोर, कलिता) के ग्राइंडिंग स्केल को सटीक रूप से परिवर्तित करें।',
    'grind.tooltip.turkish': 'बहुत बढ़िया (तुर्किये)',
    'grind.tooltip.espresso': 'पतला (इतालवी)',
    'grind.tooltip.aeropress': 'मध्यम बढ़िया (एयरोप्रेस/वी60)',
    'grind.tooltip.frenchpress': 'मध्यम दरदरा (प्रेस)',
    'grind.tooltip.coldbrew': 'अत्यधिक गाढ़ा (ठंडा काढ़ा)',
    'grind.label.turkish': 'तुर्किये',
    'grind.label.espresso': 'एस्प्रेसो',
    'grind.label.v60': 'हाथ धोना',
    'grind.label.frenchpress': 'फ़्रेंच प्रेस',
    'grind.label.coldbrew': 'ठंडा काढ़ा',
    'grind.h2_1': 'ग्राइंड स्केल रूपांतरण इतना महत्वपूर्ण क्यों है?',
    'grind.p1': 'विशेष कॉफी की दुनिया में, पीसने का आकार सबसे महत्वपूर्ण भौतिक चर है जो निष्कर्षण उपज निर्धारित करता है। अलग-अलग ग्राइंडर पूरी तरह से अलग-अलग कटरहेड ज्योमेट्री (फ्लैट बर्स, कॉनिकल बर्र्स) और अलग-अलग फाइन-ट्यूनिंग पिचों का उपयोग करते हैं, जिसका अर्थ है कि "कॉमांडेंट सी40 के 20 ग्रिड" निश्चित रूप से "टाइममोर सी2 के 20 ग्रिड" के बराबर नहीं हैं।',
    'grind.h3_1': 'यूनिवर्सल ग्राइंड रेंज',
    'grind.p2': 'हमारा एल्गोरिदम एक साधारण रैखिक गुणन नहीं है, बल्कि विभिन्न ब्रूइंग विधियों के तहत प्रत्येक ग्राइंडर के "मीठे बिंदु अंतराल" के आधार पर एक सापेक्ष स्थिति (प्रतिशत इंटरपोलेशन) रूपांतरण है:',
    'grind.li1': '<strong>अतिरिक्त महीन</strong>: आटे जितना महीन। विशेष रूप से तुर्की कॉफ़ी (सेज़वे/इब्रिक) के लिए डिज़ाइन किया गया।',
    'grind.li2': '<strong>ठीक</strong>: टेबल नमक के आकार का. एस्प्रेसो के लिए उपयुक्त, यह 9 बार का दबाव बनाने के लिए बेहतरीन जल प्रतिरोध प्रदान कर सकता है।',
    'grind.li3': '<strong>मध्यम-महीन</strong>: पोर-ओवर कॉफी (वी60, कलिता वेव) और एयरोप्रेस के लिए सर्वोत्तम। यह केवल 2-3 मिनट में खट्टे-मीठे का सही संतुलन बना लेता है।',
    'grind.li4': '<strong>मध्यम-मोटा</strong>: मोटे समुद्री नमक की तरह। अत्यधिक भिगोने के कारण होने वाली कड़वाहट से बचने के लिए फ्रेंच प्रेस या केमेक्स के लिए उपयुक्त।',
    'grind.li5': '<strong>अतिरिक्त मोटा</strong>: अशुद्धियों के निष्कासन को कम करने के लिए लंबे समय तक कम तापमान पर भिगोने के लिए उपयुक्त ठंडा काढ़ा।',
    'grind.h3_2': 'अस्वीकरण और संशोधन सुझाव',
    'grind.p3': 'कृपया ध्यान दें कि ग्राइंडर का एक ही मॉडल भी <strong>कटरहेड के घिसाव की डिग्री</strong>, <strong>शून्य बिंदु सेटिंग</strong> और <strong>कॉफी बीन्स की भुनने की डिग्री</strong> के कारण भिन्न हो सकता है। इस कनवर्टर द्वारा प्रदान किया गया मान प्रारंभिक बिंदु है। <br/> हम दृढ़तापूर्वक अनुशंसा करते हैं कि यदि बनी हुई कॉफी बहुत अधिक खट्टी (कम निकाली गई) लगती है, तो कृपया पैमाने को 1-2 कदम महीन समायोजित करें; यदि बनी हुई कॉफी जली हुई या कड़वी लगती है या पानी का प्रवाह रुका हुआ है (अति-निष्कर्षण), तो कृपया स्केल को 1-2 कदम मोटे तौर पर समायोजित करें।',
    'grind.script.turkish': 'बहुत बढ़िया (तुर्की)',
    'grind.script.espresso': 'बढ़िया पाउडर (एस्प्रेसो)',
    'grind.script.aeropress': 'मध्यम और बढ़िया (एयरोप्रेस)',
    'grind.script.v60': 'मध्यम (V60 मैनुअल)',
    'grind.script.frenchpress': 'मध्यम मोटा (फ्रेंच प्रेस)',
    'grind.script.coldbrew': 'अत्यधिक गाढ़ी (ठंडी ब्रू कॉफ़ी)',

    'history.meta.title': 'मेरा ब्रू इतिहास | बरिस्ता प्रवाह',
    'history.meta.desc': 'अपना स्वयं का कॉफ़ी लॉग बनाने के लिए अपने सभी कॉफ़ी बनाने के रिकॉर्ड और स्वाद चखने को देखें।',
    'history.title': 'मेरा शराब बनाने का इतिहास',
    'history.h1.brew': 'शराब बनाना',
    'history.h1.log': 'लकड़ी का लट्ठा',
    'history.subtitle': 'अपना आदर्श गोल्डन कप ढूंढने के लिए प्रत्येक निष्कर्षण के स्वाद का विवरण रिकॉर्ड करें।',
    'history.export': 'सीएसवी निर्यात करें',
    'history.empty.title': 'फिलहाल शराब बनाने का कोई रिकॉर्ड नहीं है',
    'history.empty.desc': 'आपके द्वारा कॉफ़ी ब्रू पूरा करने और स्वाद चखने के बाद, आपका लॉग यहां दिखाई देगा।',
    'history.empty.btn': 'शराब बनाना शुरू करें',
