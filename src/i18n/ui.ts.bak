    'tools.watertemp.cd.info': 'Info',
    'tools.watertemp.cd.info.ambient': 'Ambient',
    'tools.watertemp.cd.info.start': 'Starting',
    'tools.watertemp.cd.info.material': 'Material',
    'tools.watertemp.jsonld.name': 'Water Temp Predictor',
    'tools.watertemp.jsonld.desc': 'Accurately predict water cooling time.',
    'tools.watertemp.meta.title': 'Water Temp Predictor | Barista Flow',
    'tools.watertemp.meta.desc': 'Use Newton\'s Law of Cooling to predict your kettle\'s temperature drop.',
    'tools.watertemp.h2': 'Why Predict Water Temperature?',
    'tools.watertemp.p1': 'Water temperature is critical for extraction. Boiling water can cause over-extraction and bitterness.',
    'tools.watertemp.p2': 'Using a thermometer every time disrupts workflow.',
    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'স্টেইনলেস স্টীল হ্যান্ড ব্রু কেটলি',
    'tools.watertemp.script.impossible': 'অর্জন করতে অক্ষম',
    'tools.bean.faq.1.q': 'কফি মটরশুটি এর "degassing" প্রক্রিয়া কি?',
    'tools.bean.faq.1.a': 'রোস্টিং প্রক্রিয়া চলাকালীন, কফি মটরশুটি প্রচুর পরিমাণে কার্বন ডাই অক্সাইড উৎপন্ন করে যা কোষের কাঠামোর মধ্যে আটকে থাকে। টাটকা ভাজা কফি বিনগুলি খুব হিংস্রভাবে বের হয়ে যায়। অবিলম্বে তৈরি করা হলে, প্রচুর পরিমাণে বুদবুদ গরম জল এবং কফি পাউডারের মধ্যে যোগাযোগকে বাধা দেবে, যার ফলে অপর্যাপ্ত নিষ্কাশন এবং দুর্বল গন্ধ হবে। তথাকথিত "বিন উত্থাপন" হল কফির মটরশুটিগুলিকে কয়েকটা {t(\'tools.bean.status.days2\')} দাঁড়াতে দেওয়ার প্রক্রিয়া যাতে অতিরিক্ত কার্বন ডাই অক্সাইড প্রাকৃতিকভাবে নির্গত হয় এবং কফির স্বাদের সর্বোত্তম ভারসাম্য অর্জন করে।',
    'tools.bean.faq.2.q': 'কিভাবে সঠিকভাবে কফি মটরশুটি সতেজতা বজায় রাখা?',
    'tools.bean.faq.2.a': 'কফি বিন সংরক্ষণের তিনটি শত্রু হল: অক্সিজেন, আলো এবং আর্দ্রতা। কফি বিনগুলি সংরক্ষণ করার সর্বোত্তম উপায় হল সরাসরি সূর্যালোক ছাড়াই একটি শীতল, শুকনো আলমারিতে একমুখী নিষ্কাশন ভালভ বা একটি অস্বচ্ছ ভ্যাকুয়াম জার দিয়ে একটি সিল করা ব্যাগে রাখা। ঘন ঘন ব্যবহৃত কফি বিন ফ্রিজে রাখবেন না, কারণ রেফ্রিজারেটর খোলার এবং বন্ধ করার সময় তাপমাত্রার পার্থক্যের ফলে তৈরি হওয়া আর্দ্রতা কফি বিনগুলি দ্রুত স্যাঁতসেঁতে এবং গন্ধ শোষণের কারণ হবে।',
    'tools.bean.faq.3.a': 'হ্যাঁ, তবে কঠোর শর্ত রয়েছে। আপনি যদি প্রচুর পরিমাণে কফি বিন কিনেন যা আপনি এক মাসের মধ্যে শেষ করতে পারবেন না, আপনি সেগুলিকে ছোট একক-ব্রু অংশে (যেমন টেস্ট টিউব বা ভ্যাকুয়াম ব্যাগ) "অংশ" করতে পারেন এবং সেগুলিকে ফ্রিজে গভীরে রাখতে পারেন। আপনি যখন চোলাই করতে চান, শুধু প্রয়োজনীয় পরিমাণ বের করুন "বরফ অপসারণের দরকার নেই" এবং অবিলম্বে এটি পিষে নিন। সতর্কতা অবলম্বন করুন যে বারবার মটরশুটির পুরো ব্যাগটি ফ্রিজারের মধ্যে এবং বাইরে রাখবেন না, কারণ এটি কফির স্বাদ সম্পূর্ণরূপে নষ্ট করে দেবে।',
    'tools.bean.jsonld.name': 'কফি বিনস এবং সতেজতা ক্যালকুলেটর (বিন ফ্রেশনেস ক্যালকুলেটর)',
    'tools.bean.jsonld.desc': 'কফি বিনের রোস্টিং তারিখ এবং রোস্টিং ডিগ্রির উপর ভিত্তি করে, এটি সুবর্ণ স্বাদের সময়কালের মধ্যে কিনা তা সঠিকভাবে গণনা করতে পারে এবং পেশাদার ব্রুইং প্যারামিটার সমন্বয়ের পরামর্শ প্রদান করতে পারে।',
    'tools.bean.meta.title': 'কফি বিন চাষ এবং সতেজতা ক্যালকুলেটর | গোল্ডেন স্বাদ সময়ের পূর্বাভাস | বারিস্তা ফ্লো',
    'tools.bean.meta.desc': 'আপনার কফি মটরশুটি ভাল ক্রমবর্ধমান? রোস্টিং তারিখ লিখুন, এবং আমাদের বুদ্ধিমান কম্পিউটার আপনাকে বলবে যে কফি বিনগুলি বর্তমানে নিষ্কাশনের সময়কাল, সোনালী স্বাদের সময়কাল বা হ্রাসের সময়কালের মধ্যে আছে কিনা এবং আপনাকে সেরা তরকারির পরামর্শ দেবে৷',
    'tools.bean.title': 'কফি বিন এবং সতেজতা ক্যালকুলেটর',
    'tools.bean.subtitle': 'সেরা নিষ্কাশন সময় মাস্টার. আপনার কফির মটরশুটিগুলির বর্তমান গন্ধ এবং গ্যাস ছাড়ার অবস্থা বুঝতে রোস্টিং তারিখ এবং রোস্টিং ডিগ্রি লিখুন।',
    'tools.bean.label.date': 'মোড়কে {t(\'tools.bean.setup.date\')}',
    'tools.bean.label.level': 'রোস্ট লেভেল',
    'tools.bean.opt.light': 'হালকা রোস্ট - দীর্ঘ চাষের সময়কাল',
    'tools.bean.opt.medium': 'মাঝারি রোস্ট - স্ট্যান্ডার্ড',
    'tools.bean.opt.dark': 'ডার্ক রোস্ট - যত তাড়াতাড়ি সম্ভব পান করুন',
    'tools.bean.status.passed': 'বেকিং দিন কেটে গেছে',
    'tools.bean.status.days': 'আকাশ',
    'tools.bean.status.current': 'বর্তমান স্বাদ অবস্থা',
    'tools.bean.status.golden': 'সুবর্ণ স্বাদের সময়কাল',
    'tools.bean.status.golden.desc': 'নিষ্কাশন সম্পন্ন হয়েছে এবং স্বাদ উন্নয়ন তার শীর্ষে পৌঁছেছে। কফি বিনের এই ব্যাগের জন্য এখন সবচেয়ে সুস্বাদু মুহূর্ত।',
    'tools.bean.graph.title': 'কফি বিন জীবনচক্র বক্ররেখা',
    'tools.bean.graph.phase1': 'নিষ্কাশন সময়কাল',
    'tools.bean.graph.phase3': 'পরিপক্ক স্থিতিশীল সময়কাল',
    'tools.bean.graph.phase4': 'স্বাদ হ্রাস সময়কাল',
    'tools.bean.advice.title': 'মদ্যপান কৌশল পরামর্শ',
    'tools.bean.empty.prompt': 'অনুগ্রহ করে গণনার জন্য প্যাকেজে রোস্টিং তারিখ নির্বাচন করুন',
    'tools.bean.faq.title': 'কফি বিন সম্পর্কিত প্রায়শ জিজ্ঞাস্য প্রশ্নাবলী',
    'tools.bean.faq.3.q': 'আমি কি রেফ্রিজারেটরে কফি বিন হিমায়িত করতে পারি?',
    'tools.bean.faq.1.a_text': 'রোস্টিং প্রক্রিয়া চলাকালীন, কফি মটরশুটি প্রচুর পরিমাণে কার্বন ডাই অক্সাইড উৎপন্ন করে যা কোষের কাঠামোর মধ্যে আটকে থাকে। টাটকা ভাজা কফি বিনগুলি খুব আউটগ্যাসিং। অবিলম্বে তৈরি করা হলে, প্রচুর পরিমাণে বুদবুদ গরম জল এবং কফি পাউডারের মধ্যে যোগাযোগকে বাধা দেবে, যার ফলে অপর্যাপ্ত নিষ্কাশন এবং দুর্বল গন্ধ (অর্থাৎ, সাধারণ জল চ্যানেলের প্রভাব)। তথাকথিত "বিন উত্থাপন" হল একটি শারীরিক প্রক্রিয়া যেখানে কফি বিনগুলিকে বেশ কয়েক দিন বিশ্রামের জন্য ছেড়ে দেওয়া হয় যাতে অতিরিক্ত কার্বন ডাই অক্সাইড প্রাকৃতিকভাবে নির্গত হয় এবং কফির স্বাদের সর্বোত্তম ভারসাম্য অর্জন করা যায়।',

    'tools.default.bean.aeropress': 'গুয়াতেমালা হুইহুইতনাঙ্গো',
    'tools.default.bean.coldbrew': 'ডার্ক রোস্টেড চকলেট মিশ্রিত মটরশুটি',
    'tools.default.bean.frenchpress': 'কলম্বিয়া ধুয়েছে',
    'tools.default.bean.v60': 'ইথিওপিয়া ইরগাচেফে',
    'tools.default.grind.aeropress': 'মাঝারি থেকে সূক্ষ্ম নাকাল (যেমন সূক্ষ্ম বালি)',
    'tools.default.grind.coldbrew': 'খুব মোটা পিষে',
    'tools.default.grind.frenchpress': 'মোটা মাটি (কোশের লবণের মতো)',
    'tools.default.grind.v60': 'মাঝারি থেকে সূক্ষ্ম নাকাল (শুধুমাত্র ম্যানুয়াল গ্রাইন্ডিংয়ের জন্য)',
    'tools.v60.p3': 'Hario V60 হল বিশ্বের সবচেয়ে জনপ্রিয় হাতে তৈরি কফির যন্ত্রপাতিগুলির মধ্যে একটি৷ এর অনন্য 60-ডিগ্রি টেপারড ডিজাইন, বড়-ব্যাসের নীচের গর্ত এবং সর্পিল জলের নির্দেশিকা বারিস্তাদের জল প্রবাহ নিয়ন্ত্রণে উচ্চ মাত্রার স্বাধীনতা দেয়। কিন্তু এই কারণে, V60 জল ইনজেকশনের তাল এবং স্থায়িত্বের উপর খুব ভারী। এই <strong>{t(\'tools.v60.title\')} (V60 ক্যালকুলেটর)</strong> এবং টাইমার এই ব্যথার সমস্যা সমাধানের জন্য ডিজাইন করা হয়েছে।',
    'grind.meta.desc': 'সবচেয়ে নিখুঁত ব্রুইং প্যারামিটারগুলি খুঁজে পেতে প্রধান ব্র্যান্ডের গ্রাইন্ডারের (Comandante C40, Timemore, Fellow Ode, Baratza Encore, Kalita) গ্রাইন্ডিং স্কেলকে সঠিকভাবে রূপান্তর করুন।',
    'grind.tooltip.turkish': 'খুব ভালো (তুর্কি)',
    'grind.tooltip.espresso': 'পাতলা (ইতালীয়)',
    'grind.tooltip.aeropress': 'মাঝারি জরিমানা (AeroPres/V60)',
    'grind.tooltip.frenchpress': 'মাঝারি মোটা (প্রেস)',
    'grind.tooltip.coldbrew': 'অত্যন্ত পুরু (ঠান্ডা চোলাই)',
    'grind.label.turkish': 'তুর্কিয়ে',
    'grind.label.espresso': 'এসপ্রেসো',
    'grind.label.v60': 'হাত ফ্লাশ',
    'grind.label.frenchpress': 'ফরাসি প্রেস',
    'grind.label.coldbrew': 'ঠান্ডা চোলাই',
    'grind.h2_1': 'কেন গ্রাইন্ড স্কেল রূপান্তর এত গুরুত্বপূর্ণ?',
    'grind.p1': 'বিশেষ কফির জগতে, গ্রাইন্ড সাইজ হল সবচেয়ে গুরুত্বপূর্ণ শারীরিক পরিবর্তনশীল যা নিষ্কাশনের ফলন নির্ধারণ করে। বিভিন্ন গ্রাইন্ডার সম্পূর্ণ আলাদা কাটারহেড জ্যামিতি (ফ্ল্যাট বার, কনিক্যাল বার) এবং বিভিন্ন ফাইন-টিউনিং পিচ ব্যবহার করে, যার মানে হল "কমান্ড্যান্টে C40 এর 20 গ্রিড" অবশ্যই "টাইমোর C2 এর 20 গ্রিড" এর সমান নয়।',
    'grind.h3_1': 'ইউনিভার্সাল গ্রাইন্ড রেঞ্জ',
    'grind.p2': 'আমাদের অ্যালগরিদম একটি সরল রৈখিক গুণন নয়, বরং একটি আপেক্ষিক অবস্থান (শতাংশ ইন্টারপোলেশন) রূপান্তর যা বিভিন্ন ব্রুইং পদ্ধতির অধীনে প্রতিটি গ্রাইন্ডারের "সুইট পয়েন্টের ব্যবধান" এর উপর ভিত্তি করে:',
    'grind.li1': '<strong>অতিরিক্ত সূক্ষ্ম</strong>: ময়দার মতো মিহি। বিশেষভাবে তুর্কি কফির জন্য ডিজাইন করা হয়েছে (Cezve/Ibrik)।',
    'grind.li2': '<strong>সূক্ষ্ম</strong>: টেবিল লবণের আকার। এসপ্রেসোর জন্য উপযুক্ত, এটি 9 বারের চাপ তৈরি করতে দুর্দান্ত জল প্রতিরোধ করতে পারে।',
    'grind.li3': '<strong>মাঝারি-সূক্ষ্ম</strong>: পোর-ওভার কফি (V60, কালিতা ওয়েভ) এবং AeroPres এর জন্য সেরা। এটি মাত্র 2-3 মিনিটে মিষ্টি এবং টক এর নিখুঁত ভারসাম্য বের করে।',
    'grind.li4': '<strong>মাঝারি-মোটা</strong>: মোটা সমুদ্রের লবণের মতো। অতিরিক্ত ভিজানোর কারণে সৃষ্ট তিক্ততা এড়াতে ফ্রেঞ্চ প্রেস বা চেমেক্সের জন্য উপযুক্ত।',
    'grind.li5': '<strong>অতিরিক্ত মোটা</strong>: অমেধ্য নিষ্কাশন কমানোর জন্য দীর্ঘমেয়াদী নিম্ন-তাপমাত্রা খাড়ার জন্য উপযুক্ত কোল্ড ব্রু।',
    'grind.h3_2': 'দাবিত্যাগ এবং টুইকিং পরামর্শ',
    'grind.p3': 'অনুগ্রহ করে মনে রাখবেন যে গ্রাইন্ডারের একই মডেলও <strong>কাটারহেডের পরিধানের মাত্রা</strong>, <strong>জিরো পয়েন্ট সেটিং</strong> এবং <strong>কফি বিনের রোস্ট ডিগ্রি</strong>র কারণে পরিবর্তিত হতে পারে। এই রূপান্তরকারী দ্বারা প্রদত্ত মান হল শুরু বিন্দু। <br/> আমরা দৃঢ়ভাবে সুপারিশ করছি যে যদি তৈরি করা কফিটি খুব টক (আন্ডার-এক্সট্রাক্ট করা হয়) মনে হয় তবে দয়া করে 1-2 ধাপ সূক্ষ্ম স্কেলটি সামঞ্জস্য করুন; যদি তৈরি করা কফিটি পোড়া বা তিক্ত মনে হয় বা জলের প্রবাহ স্থির থাকে (অতিরিক্ত নিষ্কাশন), দয়া করে স্কেলটি 1-2 ধাপ মোটা করে সামঞ্জস্য করুন।',
    'grind.script.turkish': 'খুব ভালো (তুর্কি)',
    'grind.script.espresso': 'সূক্ষ্ম পাউডার (এসপ্রেসো)',
    'grind.script.aeropress': 'মাঝারি এবং সূক্ষ্ম (AeroPres)',
