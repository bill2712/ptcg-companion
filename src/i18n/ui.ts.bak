    'tools.watertemp.cd.info': 'Info',
    'tools.watertemp.cd.info.ambient': 'Ambient',
    'tools.watertemp.cd.info.start': 'Starting',
    'tools.watertemp.cd.info.material': 'Material',
    'tools.watertemp.jsonld.name': 'Water Temp Predictor',
    'tools.watertemp.jsonld.desc': 'Accurately predict water cooling time.',
    'tools.watertemp.meta.title': 'Water Temp Predictor | Barista Flow',
    'tools.watertemp.meta.desc': 'Use Newton\'s Law of Cooling to predict your kettle\'s temperature drop.',
    'tools.watertemp.h2': 'Why Predict Water Temperature?',
    'tools.watertemp.p1': 'Water temperature is critical for extraction. Boiling water can cause over-extraction and bitterness.',
    'tools.watertemp.p2': 'Using a thermometer every time disrupts workflow.',
    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'غلاية تحضير القهوة اليدوية من الفولاذ المقاوم للصدأ',
    'tools.watertemp.script.impossible': 'غير قادر على تحقيقه',
    'tools.bean.faq.1.q': 'ما هي عملية "تفريغ" حبوب البن؟',
    'tools.bean.faq.1.a': 'أثناء عملية التحميص، تنتج حبوب البن كميات كبيرة من ثاني أكسيد الكربون المحتجز داخل بنية الخلية. حبوب البن المحمصة الطازجة تخرج الغازات بعنف شديد. إذا تم تخميرها على الفور، فإن عددًا كبيرًا من الفقاعات سيمنع التلامس بين الماء الساخن ومسحوق القهوة، مما يؤدي إلى عدم كفاية الاستخلاص وضعف النكهة. إن ما يسمى بـ "تربية الفول" هو عملية ترك حبوب البن تقف لبضعة {t(\'tools.bean.status.days2\')} للسماح بإطلاق ثاني أكسيد الكربون الزائد بشكل طبيعي وتحقيق أفضل توازن لنكهة القهوة.',
    'tools.bean.faq.2.q': 'كيفية تخزين حبوب البن بشكل صحيح للحفاظ على نضارتها؟',
    'tools.bean.faq.2.a': 'الأعداء الثلاثة لحفظ حبوب البن هم: الأكسجين والضوء والرطوبة. أفضل طريقة لتخزين حبوب البن هي وضعها في كيس محكم الغلق مزود بصمام عادم أحادي الاتجاه أو في وعاء غير شفاف في خزانة باردة وجافة دون التعرض لأشعة الشمس المباشرة. لا تضع أبدًا حبوب القهوة المستخدمة بشكل متكرر في الثلاجة، لأن الرطوبة الناتجة عن اختلاف درجات الحرارة عند فتح الثلاجة وإغلاقها ستجعل حبوب القهوة رطبة بسرعة وتمتص الروائح.',
    'tools.bean.faq.3.a': 'نعم، ولكن هناك شروط صارمة. إذا اشتريت كمية كبيرة من حبوب القهوة ولم تتمكن من الانتهاء منها خلال شهر، يمكنك "تقسيمها" إلى أجزاء صغيرة للتحضير الفردي (مثل أنابيب الاختبار أو الأكياس المفرغة من الهواء) ووضعها عميقًا في الفريزر. عندما تريد تحضير القهوة، ما عليك سوى إخراج الكمية المطلوبة "لا حاجة لإزالة الثلج" وطحنها على الفور. احرص على عدم وضع كيس الحبوب بالكامل داخل وخارج الثلاجة بشكل متكرر، لأن ذلك سيدمر نكهة القهوة تمامًا.',
    'tools.bean.jsonld.name': 'حبوب البن وآلة حاسبة نضارة (آلة حاسبة نضارة الفول)',
    'tools.bean.jsonld.desc': 'استنادًا إلى تاريخ التحميص ودرجة تحميص حبوب القهوة، يمكنه حساب ما إذا كانت في فترة النكهة الذهبية بدقة وتقديم اقتراحات تعديل معلمات التخمير الاحترافية.',
    'tools.bean.meta.title': 'حاسبة زراعة حبوب البن ونضارتها | التنبؤ بفترة النكهة الذهبية | تدفق باريستا',
    'tools.bean.meta.desc': 'هل تنمو حبوب البن لديك بشكل جيد؟ أدخل تاريخ التحميص، وسيخبرك جهاز الكمبيوتر الذكي الخاص بنا ما إذا كانت حبوب القهوة حاليًا في فترة الاستنفاد، أو فترة النكهة الذهبية، أو فترة الانخفاض، وسيقدم لك أفضل اقتراحات التخمير.',
    'tools.bean.title': 'حبوب البن وآلة حاسبة النضارة',
    'tools.bean.subtitle': 'إتقان أفضل وقت الاستخراج. أدخل تاريخ التحميص ودرجة التحميص لفهم النكهة الحالية وظروف انبعاث الغازات لحبوب القهوة الخاصة بك.',
    'tools.bean.label.date': '{t(\'tools.bean.setup.date\')} على الغلاف',
    'tools.bean.label.level': 'مستوى الشواء',
    'tools.bean.opt.light': 'مشوي خفيف - فترة زراعة أطول',
    'tools.bean.opt.medium': 'تحميص متوسط ​​- قياسي',
    'tools.bean.opt.dark': 'تحميص داكن - اشرب في أسرع وقت ممكن',
    'tools.bean.status.passed': 'لقد مر يوم الخبز',
    'tools.bean.status.days': 'سماء',
    'tools.bean.status.current': 'حالة النكهة الحالية',
    'tools.bean.status.golden': 'فترة النكهة الذهبية',
    'tools.bean.status.golden.desc': 'اكتمل العادم ووصل تطور النكهة إلى ذروته. الآن هي اللحظة اللذيذة لهذه الحقيبة من حبوب القهوة.',
    'tools.bean.graph.title': 'منحنى دورة حياة حبة البن',
    'tools.bean.graph.phase1': 'فترة العادم',
    'tools.bean.graph.phase3': 'فترة مستقرة ناضجة',
    'tools.bean.graph.phase4': 'فترة تراجع النكهة',
    'tools.bean.advice.title': 'اقتراحات استراتيجية التخمير',
    'tools.bean.empty.prompt': 'يرجى تحديد تاريخ التحميص على العبوة لإجراء الحساب',
    'tools.bean.faq.title': 'الأسئلة المتداولة حول حبوب البن',
    'tools.bean.faq.3.q': 'هل يمكنني تجميد حبوب البن في الثلاجة؟',
    'tools.bean.faq.1.a_text': 'أثناء عملية التحميص، تنتج حبوب البن كميات كبيرة من ثاني أكسيد الكربون المحتجز داخل بنية الخلية. حبوب البن المحمصة الطازجة تطلق الغازات بشكل كبير. إذا تم تخميرها على الفور، فإن عددًا كبيرًا من الفقاعات سيمنع التلامس بين الماء الساخن ومسحوق القهوة، مما يؤدي إلى عدم كفاية الاستخلاص ونكهة ضعيفة (أي تأثير قناة الماء الشائعة). إن ما يسمى بـ "تربية الفول" هي عملية فيزيائية يتم فيها ترك حبوب البن لترتاح لعدة أيام للسماح بإطلاق ثاني أكسيد الكربون الزائد بشكل طبيعي وتحقيق أفضل توازن لنكهة القهوة.',

    'tools.default.bean.aeropress': 'غواتيمالا هويهويتنانجو',
    'tools.default.bean.coldbrew': 'الشوكولاته الداكنة المحمصة الفاصوليا المختلطة',
    'tools.default.bean.frenchpress': 'غسلت كولومبيا',
    'tools.default.bean.v60': 'إثيوبيا يرغاتشيف',
    'tools.default.grind.aeropress': 'طحن متوسط ​​إلى ناعم (مثل الرمل الناعم)',
    'tools.default.grind.coldbrew': 'طحن خشن جدا',
    'tools.default.grind.frenchpress': 'مطحون خشن (مثل ملح الكوشير)',
    'tools.default.grind.v60': 'طحن متوسط ​​إلى ناعم (للطحن اليدوي فقط)',
    'tools.v60.p3': 'يعد Hario V60 واحدًا من أشهر أجهزة صنع القهوة المصنوعة يدويًا في العالم. إن تصميمها الفريد المدبب بزاوية 60 درجة، والفتحة السفلية ذات القطر الكبير ودليل المياه الحلزوني يمنح صانعي القهوة درجة عالية من الحرية في التحكم في تدفق المياه. ولكن لهذا السبب، فإن محرك V60 ثقيل جدًا على إيقاع واستقرار حقن الماء. تم تصميم <strong>{t(\'tools.v60.title\')} (V60 Calculator)</strong> والمؤقت لحل مشكلة المشكلة هذه.',
    'grind.meta.desc': 'قم بتحويل موازين الطحن الخاصة بالعلامات التجارية الكبرى للمطاحن (Comandante C40، وTimemore، وFellow Ode، وBaratza Encore، وKalita) بدقة للعثور على معلمات التخمير الأكثر مثالية.',
    'grind.tooltip.turkish': 'جيد جدًا (تركيا)',
    'grind.tooltip.espresso': 'رفيع (إيطالي)',
    'grind.tooltip.aeropress': 'متوسطة الجودة (AeroPress/V60)',
    'grind.tooltip.frenchpress': 'خشنة متوسطة (صحافة)',
    'grind.tooltip.coldbrew': 'سميكة للغاية (الشراب البارد)',
    'grind.label.turkish': 'تركيا',
    'grind.label.espresso': 'اسبريسو',
    'grind.label.v60': 'تدفق اليد',
    'grind.label.frenchpress': 'الصحافة الفرنسية',
    'grind.label.coldbrew': 'المشروب البارد',
    'grind.h2_1': 'لماذا يعد تحويل مقياس الطحن مهمًا جدًا؟',
    'grind.p1': 'في عالم القهوة المتخصصة، يعد حجم الطحن هو المتغير الفيزيائي الأكثر أهمية الذي يحدد إنتاجية الاستخلاص. تستخدم المطاحن المختلفة أشكالًا هندسية مختلفة تمامًا لرؤوس القطع (شفرات مسطحة، وشفرات مخروطية) ودرجات ضبط دقيقة مختلفة، مما يعني أن "شبكات Comandante C40\'s 20" لا تساوي بالتأكيد "شبكات Timemore C2\'s 20".',
    'grind.h3_1': 'نطاقات الطحن العالمية',
    'grind.p2': 'الخوارزمية الخاصة بنا ليست ضربًا خطيًا بسيطًا، ولكنها تحويل موضع نسبي (استيفاء النسبة المئوية) استنادًا إلى "الفاصل الزمني للنقطة الحلوة" لكل مطحنة تحت طرق تخمير مختلفة:',
    'grind.li1': '<strong>ناعم جدًا</strong>: ناعم مثل الدقيق. مصممة خصيصًا للقهوة التركية (سيزفي/إيبريك).',
    'grind.li2': '<strong>الناعمة</strong>: بحجم ملح الطعام. مناسبة للإسبريسو، ويمكن أن توفر مقاومة رائعة للماء لبناء ضغط يصل إلى 9 بار.',
    'grind.li3': '<strong>متوسطة-ناعمة</strong>: الأفضل لتحضير القهوة المصبوبة (V60، وKalita Wave) وAeroPress. فهو يستخرج التوازن المثالي بين الحلو والحامض في 2-3 دقائق فقط.',
    'grind.li4': '<strong>متوسط-خشن</strong>: مثل ملح البحر الخشن. مناسب للفرنش برس أو كيمكس لتجنب المرارة الناتجة عن النقع الزائد.',
    'grind.li5': '<strong>خشن للغاية</strong>: مشروب بارد مناسب للنقع في درجة حرارة منخفضة على المدى الطويل لتقليل استخلاص الشوائب.',
    'grind.h3_2': 'إخلاء المسؤولية واقتراحات التغيير والتبديل',
    'grind.p3': 'يرجى ملاحظة أنه حتى نفس طراز المطحنة قد يختلف بسبب <strong>درجة تآكل رأس التقطيع</strong>، و<strong>إعداد نقطة الصفر</strong> و<strong>درجة تحميص حبوب القهوة</strong>. القيمة المقدمة بواسطة هذا المحول هي نقطة البداية. <br/> نوصي بشدة أنه إذا كانت القهوة المخمرة تبدو شديدة الحموضة (ناقصة الاستخلاص)، فيرجى ضبط المقياس بمقدار 1-2 خطوة أدق؛ إذا كانت القهوة المخمرة محروقة أو مريرة أو كان تدفق الماء راكدًا (الإفراط في الاستخلاص)، فيرجى ضبط المقياس بمقدار 1-2 خطوة أكثر خشونة.',
    'grind.script.turkish': 'جيد جدًا (تركي)',
    'grind.script.espresso': 'مسحوق ناعم (اسبريسو)',
    'grind.script.aeropress': 'المتوسطة والناعمة (ايروبريس)',
    'grind.script.v60': 'متوسطة (دليل V60)',
