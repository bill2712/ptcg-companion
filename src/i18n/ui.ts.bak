    'tools.watertemp.p3': 'This tool uses physics to calculate the exact wait time for your water to naturally cool to the perfect target temperature.',
    'tools.watertemp.script.stainless': 'سٹینلیس سٹیل ہینڈ بریو کیتلی',
    'tools.watertemp.script.impossible': 'حاصل کرنے سے قاصر ہے۔',
    'tools.bean.faq.1.q': 'کافی پھلیاں کا "ڈیگاسنگ" عمل کیا ہے؟',
    'tools.bean.faq.1.a': 'بھوننے کے عمل کے دوران، کافی کی پھلیاں بڑی مقدار میں کاربن ڈائی آکسائیڈ پیدا کرتی ہیں جو سیل کے ڈھانچے کے اندر بند ہوتی ہے۔ تازہ بھنی ہوئی کافی کی پھلیاں بہت پرتشدد طریقے سے نکلتی ہیں۔ اگر فوری طور پر پیا جائے تو بڑی تعداد میں بلبلے گرم پانی اور کافی پاؤڈر کے درمیان رابطے کو روکیں گے، جس کے نتیجے میں ناکافی اخراج اور ذائقہ کمزور ہوگا۔ نام نہاد "بین ریزنگ" کافی کی پھلیوں کو چند {t(\'tools.bean.status.days2\')} کے لیے کھڑا رہنے دینے کا عمل ہے تاکہ اضافی کاربن ڈائی آکسائیڈ کو قدرتی طور پر خارج کیا جا سکے اور کافی کے ذائقے کا بہترین توازن حاصل کیا جا سکے۔',
    'tools.bean.faq.2.q': 'تازگی کو برقرار رکھنے کے لیے کافی کی پھلیاں کیسے محفوظ کی جائیں؟',
    'tools.bean.faq.2.a': 'کافی کی پھلیاں محفوظ کرنے کے تین دشمن ہیں: آکسیجن، روشنی اور نمی۔ کافی کی پھلیاں ذخیرہ کرنے کا بہترین طریقہ یہ ہے کہ انہیں ایک مہر بند بیگ میں یک طرفہ ایگزاسٹ والو یا مبہم ویکیوم جار کے ساتھ ٹھنڈی، خشک الماری میں براہ راست سورج کی روشنی کے بغیر رکھیں۔ کثرت سے استعمال ہونے والی کافی کی پھلیاں کبھی بھی ریفریجریٹر میں نہ رکھیں، کیونکہ ریفریجریٹر کو کھولنے اور بند کرتے وقت درجہ حرارت کے فرق سے پیدا ہونے والی نمی کافی کی پھلیاں جلد نم ہونے اور بدبو جذب کرنے کا سبب بنتی ہے۔',
    'tools.bean.faq.3.a': 'ہاں، لیکن سخت شرائط ہیں۔ اگر آپ کافی بینز کی ایک بڑی مقدار خریدتے ہیں جو آپ ایک ماہ کے اندر ختم نہیں کر سکتے ہیں، تو آپ انہیں چھوٹے سنگل بریو حصوں (جیسے ٹیسٹ ٹیوب یا ویکیوم بیگ) میں "حصہ" کر سکتے ہیں اور انہیں فریزر میں گہرائی میں رکھ سکتے ہیں۔ جب آپ پکنا چاہیں تو صرف مطلوبہ مقدار نکال لیں "برف کو ہٹانے کی ضرورت نہیں" اور اسے فوراً پیس لیں۔ ہوشیار رہیں کہ پھلیاں کے پورے تھیلے کو بار بار فریزر کے اندر اور باہر نہ رکھیں، کیونکہ اس سے کافی کا ذائقہ بالکل ختم ہو جائے گا۔',
    'tools.bean.jsonld.name': 'کافی کی پھلیاں اور تازگی کا کیلکولیٹر (بین تازگی کیلکولیٹر)',
    'tools.bean.jsonld.desc': 'کافی کی پھلیاں بھوننے کی تاریخ اور بھوننے کی ڈگری کی بنیاد پر، یہ درست طریقے سے اندازہ لگا سکتا ہے کہ آیا یہ سنہری ذائقہ کی مدت میں ہے اور پیشہ ورانہ پیرامیٹر ایڈجسٹمنٹ کی تجاویز فراہم کرتا ہے۔',
    'tools.bean.meta.title': 'کافی بین کی کاشت اور تازگی کیلکولیٹر | سنہری ذائقہ کی مدت کی پیشن گوئی | بارسٹا فلو',
    'tools.bean.meta.desc': 'کیا آپ کی کافی پھلیاں اچھی طرح بڑھ رہی ہیں؟ بھوننے کی تاریخ درج کریں، اور ہمارا ذہین کمپیوٹر آپ کو بتائے گا کہ آیا کافی کی پھلیاں فی الحال ختم ہونے کی مدت میں ہیں، سنہری ذائقہ کی مدت یا کمی کی مدت میں، اور آپ کو بہترین پکنے کی تجاویز دے گا۔',
    'tools.bean.title': 'کافی پھلیاں اور تازگی کیلکولیٹر',
    'tools.bean.subtitle': 'بہترین نکالنے کے وقت میں مہارت حاصل کریں۔ اپنی کافی کی پھلیاں کے موجودہ ذائقے اور گیس نہ ہونے کے حالات کو سمجھنے کے لیے بھوننے کی تاریخ اور بھوننے کی ڈگری درج کریں۔',
