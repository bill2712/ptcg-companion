---
import Layout from '../layouts/Layout.astro';
import PTCGCounter from '../components/PTCGCounter';
import { t } from '../locales/translations';

const lang = "en";
const title = t(lang, 'metaTitle');
const description = t(lang, 'metaDesc');
const keywords = t(lang, 'metaKeywords');
---

<Layout title={title} description={description} keywords={keywords} lang={lang}>
	<main class="w-full min-h-screen bg-black flex items-center justify-center">
		<PTCGCounter lang={lang} client:load />
	</main>
</Layout>
