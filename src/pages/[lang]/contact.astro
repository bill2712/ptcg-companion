---
import Layout from '../../layouts/Layout.astro';
import { langs } from '../../locales/translations';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const title = "Contact Us - PTCG Companion";
---

<Layout title={title} lang={lang}>
  <div class="min-h-screen bg-black text-neutral-300 py-12 px-6 pb-24">
    <div class="max-w-3xl mx-auto bg-neutral-900 border border-neutral-800 p-8 rounded-2xl shadow-2xl">
      <h1 class="text-3xl font-black text-white mb-6">Contact Us</h1>
      
      <div class="space-y-6 text-sm leading-relaxed">
        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">Support Channels</h2>
          <p>For any inquiries, feedback, or feature requests regarding the application, please reach out to our global support channels.</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">Compliance and Privacy</h2>
          <p>This web application utilizes browser <code>localStorage</code> locally to save match parameters and user historical logs. It integrates Google Analytics 4 (GA4) to collect anonymous global traffic metrics. Additionally, this domain serves programmatic advertisements through Google AdSense and complies with user-privacy choices.</p>
          <p class="mt-4">If you have any questions regarding these compliance measures, please contact our Data Protection Officer.</p>
        </section>
      </div>
    </div>
  </div>
</Layout>
