---
import Layout from '../../layouts/Layout.astro';
import { langs, t } from '../../locales/translations';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const title = `${t(lang as string, 'contactTitle')} - PTCG Companion`;
---

<Layout title={title} lang={lang}>
  <div class="min-h-screen bg-black text-neutral-300 py-12 px-6 pb-24">
    <div class="max-w-3xl mx-auto bg-neutral-900 border border-neutral-800 p-8 rounded-2xl shadow-2xl">
      <h1 class="text-3xl font-black text-white mb-6">{t(lang as string, 'contactTitle')}</h1>
      
      <div class="space-y-6 text-sm leading-relaxed">
        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">{t(lang as string, 'contactSupportChannels')}</h2>
          <p>{t(lang as string, 'contactSupportDesc')}</p>
          <p class="mt-2 text-lg font-mono"><a href="mailto:beyond01hk@gmail.com" class="text-blue-400 hover:underline">beyond01hk@gmail.com</a></p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">{t(lang as string, 'contactCompliance')}</h2>
          <p>{t(lang as string, 'contactComplianceDesc').split('localStorage')[0]}<code>localStorage</code>{t(lang as string, 'contactComplianceDesc').split('localStorage')[1]}</p>
          <p class="mt-4">{t(lang as string, 'contactOfficer')}</p>
        </section>
      </div>
    </div>
  </div>
</Layout>
