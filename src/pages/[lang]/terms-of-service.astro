---
import Layout from '../../layouts/Layout.astro';
import { langs } from '../../locales/translations';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const title = "Terms of Service - PTCG Companion";
---

<Layout title={title} lang={lang}>
  <div class="min-h-screen bg-black text-neutral-300 py-12 px-6 pb-24">
    <div class="max-w-3xl mx-auto bg-neutral-900 border border-neutral-800 p-8 rounded-2xl shadow-2xl">
      <h1 class="text-3xl font-black text-white mb-6">Terms of Service</h1>
      
      <div class="space-y-6 text-sm leading-relaxed">
        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">1. Application Usage</h2>
          <p>PTCG Companion is a utility application designed for Pokémon Trading Card Game players. By using this application, you agree to these terms. This web application utilizes browser <code>localStorage</code> locally to save match parameters and user historical logs.</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">2. Data & Analytics</h2>
          <p>This application integrates Google Analytics 4 (GA4) to collect anonymous global traffic metrics. You agree that this telemetry data is collected to improve the application's core functionality and global reach.</p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-indigo-400 mb-2">3. Advertisement Network</h2>
          <p>This domain serves programmatic advertisements through Google AdSense and complies with user-privacy choices. By utilizing our free services, you acknowledge the presence of programmatic ads.</p>
        </section>
      </div>
    </div>
  </div>
</Layout>
